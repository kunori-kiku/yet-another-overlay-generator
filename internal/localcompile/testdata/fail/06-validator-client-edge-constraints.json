        "public_endpoints": [ { "id": "rb-ep", "host": "router-b.example.com", "port": 51820 } ] },
      { "id": "client-a", "name": "client-a", "platform": "debian", "role": "client", "domain_id": "d1",
        "capabilities": {} },
      { "id": "client-b", "name": "client-b", "platform": "debian", "role": "client", "domain_id": "d1",
        "capabilities": {} }
    ],
    "edges": [
      { "id": "e-out", "from_node_id": "client-a", "to_node_id": "router-a", "type": "public-endpoint", "endpoint_host": "router-a.example.com", "transport": "udp", "is_enabled": true },
      { "id": "e-bk", "from_node_id": "client-a", "to_node_id": "router-a", "type": "public-endpoint", "endpoint_host": "router-a.example.com", "role": "backup", "transport": "udp", "is_enabled": true },
      { "id": "e-client-pin", "from_node_id": "client-b", "to_node_id": "router-b", "type": "public-endpoint", "endpoint_host": "router-b.example.com", "transport": "udp", "is_enabled": true,
        "pinned_to_port": 51901,
        "pinned_from_transit_ip": "10.10.0.5", "pinned_to_transit_ip": "10.10.0.6",
        "pinned_from_link_local": "fe80::5", "pinned_to_link_local": "fe80::6" }
