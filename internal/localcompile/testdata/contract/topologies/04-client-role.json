        "public_endpoints": [ { "id": "router-a-ep", "host": "router-a.example.com", "port": 51820 } ],
        "wireguard_private_key": "wFKYOOqtvK/YveTzNg98Eb4Prt6oHae1pOpD4FkdX1U="
      },
      {
        "id": "client-a", "name": "client-a", "hostname": "client-a.local", "platform": "debian",
        "role": "client", "domain_id": "domain-1",
        "capabilities": {},
        "wireguard_private_key": "CMsYv43SL92ua2uUiANLL7bTu+tLO90YB++SVwSulH8="
      }
    ],
    "edges": [
      { "id": "e-client", "from_node_id": "client-a", "to_node_id": "router-a", "type": "public-endpoint", "endpoint_host": "router-a.example.com", "transport": "udp", "is_enabled": true }
