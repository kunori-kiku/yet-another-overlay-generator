{
  "name": "mimic-tcp",
  "doc": "Two routers joined by a transport=tcp (mimic) link. The mimic transport sets the interface MTU to effective-12 and flips the install.sh into the eBPF UDP->fake-TCP path. node-alpha sets xdp_mode=native; node-beta defaults (skb). Pins the mimic rendering surface.",
  "custody": "airgap",
  "signing": false,
  "topology": {
    "project": { "id": "mimic-tcp", "name": "Mimic TCP" },
    "domains": [
      { "id": "domain-1", "name": "mimic-net", "cidr": "10.31.0.0/24", "allocation_mode": "auto", "routing_mode": "babel" }
    ],
    "nodes": [
      {
        "id": "node-alpha", "name": "alpha", "hostname": "alpha.example.com", "platform": "debian",
        "role": "router", "domain_id": "domain-1", "xdp_mode": "native",
        "capabilities": { "can_accept_inbound": true, "can_forward": true, "has_public_ip": true },
        "public_endpoints": [ { "id": "alpha-ep", "host": "alpha.example.com", "port": 51820 } ],
        "wireguard_private_key": "+NOf/2l0pnbz3g7hm+DMiVowUoYPwppUs8z5iz01+V4="
      },
      {
        "id": "node-beta", "name": "beta", "hostname": "beta.example.com", "platform": "ubuntu",
        "role": "router", "domain_id": "domain-1",
        "capabilities": { "can_accept_inbound": true, "can_forward": true, "has_public_ip": true },
        "public_endpoints": [ { "id": "beta-ep", "host": "beta.example.com", "port": 51820 } ],
        "wireguard_private_key": "SH/Te0Jw3dIijStvm889gwZ919RXSGrwEL8hnSRwB0U="
      }
    ],
    "edges": [
      { "id": "e1", "from_node_id": "node-alpha", "to_node_id": "node-beta", "type": "public-endpoint", "endpoint_host": "beta.example.com", "transport": "tcp", "is_enabled": true }
    ]
  }
}
