{
  "files": {
    "router-a": {
      "babel/babeld.conf": "# Babel configuration for router-a\n# Generated by Overlay Network Config Orchestrator\n# Role: router\n\nrouter-id aa:4c:f2:44:25:f8\nlocal-port 33123\nskip-kernel-setup false\n\n# Route redistribution\nredistribute local ip 10.40.16.1/32 allow\nredistribute local ip 10.40.16.0/24 allow\n# Deny all other local routes\nredistribute local deny\n\n# WireGuard tunnel interfaces\ninterface wg-router-b type tunnel hello-interval 4 update-interval 16\ninterface wg-router-c type tunnel hello-interval 4 update-interval 16\ninterface wg-router-d type tunnel hello-interval 4 update-interval 16\n",
      "install.sh": "#!/usr/bin/env bash\n# Install script for node: router-a\n# Generated by Overlay Network Config Orchestrator\n# Platform: debian\n# Role: router\n# Architecture: per-peer WireGuard interfaces\n#\n# Usage:\n#   sudo bash install.sh              # Install / upgrade overlay\n#   sudo bash install.sh --uninstall  # Completely remove overlay\n\nset -euo pipefail\n\nUNINSTALL=0\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --uninstall|-u) UNINSTALL=1 ;;\n    esac\ndone\n\n# ============================================================\n# Uninstall All\n# ============================================================\n\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    # Check root\n    if [ \"$(id -u)\" -ne 0 ]; then\n        echo \"ERROR: This script must be run as root\" \u003e\u00262\n        exit 1\n    fi\n\n    echo \"=== Uninstalling overlay from node: \"'router-a'\" ===\"\n\n# Stop and disable all managed WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-b\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-b...\"\n        wg-quick down \"wg-router-b\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-b\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-b\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-b.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-c...\"\n        wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-d\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-d...\"\n        wg-quick down \"wg-router-d\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-d\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-d\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-d.conf\"\n    # Stop and disable ALL remaining WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261; then\n        for _iface in $(wg show interfaces 2\u003e/dev/null); do\n            echo \"  Stopping WireGuard interface: $_iface...\"\n            wg-quick down \"$_iface\" 2\u003e/dev/null || true\n            systemctl disable \"wg-quick@$_iface\" 2\u003e/dev/null || true\n        done\n    fi\n    rm -f /etc/wireguard/*.conf\n\n# Stop and disable Babel\n    if systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Stopping Babel daemon...\"\n        systemctl stop babeld 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable babeld 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"\n    rm -rf /etc/systemd/system/babeld.service.d\n# Remove sysctl config\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    sysctl --system \u003e /dev/null 2\u003e\u00261\n\n    # Remove overlay SNAT rule and service\n    #\n    # D52: same as _overlay_snat_cleanup - delete each rule whole, matched by wg interface + transit\n    # source pool and ignoring --to-source, so uninstall fully clears even stale rules left by a prior overlay IP change.\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Chained grep -F deletes each matching rule whole, order-independent; see Phase 1's _overlay_snat_cleanup.\n        # grep returns 1 on no match; with set -o pipefail that makes the pipe non-zero and aborts under set -e, so || true guards it.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n    if systemctl is-enabled overlay-snat.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-snat.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-snat.service\n\n    # Remove dummy0 overlay interface and its systemd service\n    if ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Removing dummy0 interface...\"\n        ip link del dummy0 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled overlay-dummy.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-dummy.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-dummy.service\n    systemctl daemon-reload\n\n    echo \"\"\n    echo \"============================================================\"\n    echo \"  Overlay completely removed from node: \"'router-a'\n    echo \"============================================================\"\n    exit 0\nfi\n\n# ============================================================\n# Phase 0: Cleanup Previous Installation\n# ============================================================\n\necho \"=== Phase 0: Cleanup Previous Installation ===\"\n\n# Stop all WireGuard interfaces managed by this overlay\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-b\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-b...\"\n    wg-quick down \"wg-router-b\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-b\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-b\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-b.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-b.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-b.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-c...\"\n    wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-c.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-c.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-d\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-d...\"\n    wg-quick down \"wg-router-d\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-d\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-d\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-d.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-d.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-d.conf\"\nfi\n# Clean up ALL legacy/stale WireGuard interfaces and configs\n# This catches wg0, wg1, wg-overlay, or any other leftover profiles\nif command -v wg \u003e/dev/null 2\u003e\u00261; then\n    for _legacy_iface in $(wg show interfaces 2\u003e/dev/null); do\n        # Skip interfaces managed by this overlay (already handled above)\n        _is_managed=false\n        [ \"$_legacy_iface\" = \"wg-router-b\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-c\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-d\" ] \u0026\u0026 _is_managed=true\n        if [ \"$_is_managed\" = \"false\" ]; then\n            echo \"  Stopping legacy WireGuard interface: $_legacy_iface...\"\n            wg-quick down \"$_legacy_iface\" 2\u003e/dev/null || true\n            if systemctl is-enabled \"wg-quick@$_legacy_iface\" \u003e/dev/null 2\u003e\u00261; then\n                systemctl disable \"wg-quick@$_legacy_iface\" 2\u003e/dev/null || true\n            fi\n        fi\n    done\nfi\n# Remove any leftover WireGuard config files not managed by this overlay\nfor _legacy_conf in /etc/wireguard/*.conf; do\n    [ -f \"$_legacy_conf\" ] || continue\n    _legacy_name=\"$(basename \"$_legacy_conf\")\"\n    _is_managed=false\n    [ \"$_legacy_name\" = \"wg-router-b.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-c.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-d.conf\" ] \u0026\u0026 _is_managed=true\n    if [ \"$_is_managed\" = \"false\" ]; then\n        rm -f \"$_legacy_conf\"\n        echo \"  Removed legacy config: $_legacy_conf\"\n    fi\ndone\n\n# Stop Babel if running\nif systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n    echo \"  Stopping Babel daemon...\"\n    systemctl stop babeld 2\u003e/dev/null || true\nfi\nif systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable babeld 2\u003e/dev/null || true\nfi\nfor _bcf in \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"; do\n    if [ -f \"$_bcf\" ]; then\n        rm -f \"$_bcf\"\n        echo \"  Removed old Babel config: $_bcf\"\n    fi\ndone\nif [ -f \"/etc/sysctl.d/99-overlay.conf\" ]; then\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    echo \"  Removed old sysctl config\"\nfi\n\necho \"Phase 0 complete.\"\n\n# ============================================================\n# Phase 1: Environment Preparation\n# ============================================================\n\necho \"=== Phase 1: Environment Preparation ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Verify checksums if available\nif [ -f \"$SCRIPT_DIR/checksums.sha256\" ]; then\n    echo \"Verifying file integrity...\"\n    cd \"$SCRIPT_DIR\"\n    if ! sha256sum --status -c checksums.sha256; then\n        echo \"ERROR: Checksum validation failed!\" \u003e\u00262\n        exit 1\n    fi\n    echo \"Checksum validation passed.\"\n    cd - \u003e/dev/null\nfi\n\n# Check root\nif [ \"$(id -u)\" -ne 0 ]; then\n    echo \"ERROR: This script must be run as root\" \u003e\u00262\n    exit 1\nfi\n\n# Detect OS\nif [ -f /etc/os-release ]; then\n    . /etc/os-release\n    OS_ID=\"$ID\"\n    OS_VERSION=\"$VERSION_ID\"\n    echo \"Detected OS: $OS_ID $OS_VERSION\"\nelse\n    echo \"ERROR: Cannot detect OS\" \u003e\u00262\n    exit 1\nfi\n\n# Install dependencies (cross-distro, idempotent)\n#\n# This runs on EVERY controller apply (the daemon re-runs install.sh per generation) and on a\n# manual air-gap run, so it is a fast no-op once the tools exist: each MISSING command is mapped\n# to a package and installed via the detected manager. Supported: apt / dnf / yum / zypper /\n# pacman / apk. Package names match across managers except iproute2 -\u003e iproute on dnf/yum/zypper.\n# An unknown manager with tools still missing fails with an explicit list (no confusing mid-run error).\necho \"Installing dependencies...\"\n\nYAOG_PM=\"\"\nfor _c in apt-get dnf yum zypper pacman apk; do\n    if command -v \"$_c\" \u003e/dev/null 2\u003e\u00261; then YAOG_PM=\"$_c\"; break; fi\ndone\n\n_pm_pkg() { # map a generic package name to this manager's concrete name\n    case \"$1:$YAOG_PM\" in\n        iproute2:dnf|iproute2:yum|iproute2:zypper) echo iproute ;;\n        *) echo \"$1\" ;;\n    esac\n}\n\n_PM_REFRESHED=0\n_pm_install() {\n    local _pkg; _pkg=\"$(_pm_pkg \"$1\")\"\n    if [ \"$_PM_REFRESHED\" -eq 0 ]; then\n        case \"$YAOG_PM\" in\n            apt-get) apt-get update -qq || true ;;\n            apk)     apk update \u003e/dev/null 2\u003e\u00261 || true ;;\n        esac\n        _PM_REFRESHED=1\n    fi\n    case \"$YAOG_PM\" in\n        apt-get) DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \"$_pkg\" ;;\n        dnf)     dnf install -y \"$_pkg\" ;;\n        yum)     yum install -y \"$_pkg\" ;;\n        zypper)  zypper --non-interactive install \"$_pkg\" ;;\n        pacman)  pacman -Sy --noconfirm \"$_pkg\" ;;\n        apk)     apk add --no-progress \"$_pkg\" ;;\n        *)       return 1 ;;\n    esac\n}\n\nYAOG_MISSING=\"\"\nensure_cmd() { # ensure_cmd \u003ccommand\u003e \u003cgeneric-package\u003e: install only if the command is absent\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 \u0026\u0026 return 0\n    if [ -n \"$YAOG_PM\" ]; then\n        echo \"  - installing $2 (provides '$1')\"\n        _pm_install \"$2\" || true\n    fi\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || YAOG_MISSING=\"$YAOG_MISSING $1\"\n}\n\nensure_cmd wg       wireguard-tools\nensure_cmd wg-quick wireguard-tools\nensure_cmd ip       iproute2\nensure_cmd openssl  openssl\n# SNAT uses nft when present, else iptables (+iptables-save, same package) — ensure one exists.\nif ! command -v nft \u003e/dev/null 2\u003e\u00261 \u0026\u0026 ! command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    ensure_cmd iptables iptables\nfi\nensure_cmd babeld babeld\nif [ -n \"$YAOG_MISSING\" ]; then\n    echo \"ERROR: missing required tools:$YAOG_MISSING\" \u003e\u00262\n    echo \"  No supported package manager installed them automatically. Install the equivalents of\" \u003e\u00262\n    echo \"  wireguard-tools (wg, wg-quick), iproute2 (ip), openssl, iptables or nftables, babeld, then re-run.\" \u003e\u00262\n    exit 1\nfi\n\n# WireGuard kernel module: built into Linux \u003e= 5.6; load it (best-effort) on older kernels.\n# If it is genuinely unavailable, wg-quick below surfaces the real error per interface.\nmodprobe wireguard 2\u003e/dev/null || true\n\nmkdir -p /etc/wireguard\nmkdir -p /etc/babel\n# Create dummy0 interface for stable overlay address\nif ! ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n    echo \"Creating dummy0 interface for overlay address...\"\n    ip link add dummy0 type dummy\nfi\nip addr flush dev dummy0 2\u003e/dev/null || true\nip addr add 10.40.16.1/32 dev dummy0\nip link set dummy0 up\necho \"  Overlay address 10.40.16.1/32 assigned to dummy0\"\n\n# Make dummy0 persistent across reboots\ncat \u003e /etc/systemd/system/overlay-dummy.service \u003c\u003c 'DUMMY_SVC'\n[Unit]\nDescription=Overlay dummy interface\nBefore=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/sbin/ip link add dummy0 type dummy\nExecStart=/sbin/ip addr add 10.40.16.1/32 dev dummy0\nExecStart=/sbin/ip link set dummy0 up\nExecStop=/sbin/ip link del dummy0\n\n[Install]\nWantedBy=multi-user.target\nDUMMY_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-dummy.service 2\u003e/dev/null || true\n\n# Fix source address selection for overlay traffic\n# Without this, packets to overlay IPs use the transit IP (10.10.0.x) as source\n# instead of the overlay IP, causing silent failures for plain \"ping \u003coverlay_ip\u003e\"\necho \"Configuring overlay source address fix...\"\n\n# Remove any previous overlay SNAT rules\n#\n# D52: we cannot delete by an exact rule (with --to-source \u003ccurrent overlay IP\u003e): after an overlay IP change a\n# reinstall would leave the old --to-source rule in POSTROUTING, wrongly source-rewriting packets to the old address.\n# Instead: parse iptables-save and delete EVERY POSTROUTING SNAT rule matching the wg interface + transit source\n# pool, whole, regardless of its --to-source. The nft path drops the whole table and has no such problem, so it is left as-is.\n_overlay_snat_cleanup() {\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Delete rule by rule: in the iptables-save output, every POSTROUTING rule whose out interface is wg-+, source is 10.40.0.0/28,\n        # and action is SNAT is turned into a -D delete using its full parameters (ignoring the specific --to-source value).\n        # Use chained grep -F rather than a single order-assuming regex: iptables-save normalizes parameter order\n        # (usually -s before -o), so fixed-string matching is order-independent and needs no escaping of the . and / in the CIDR.\n        # grep returns 1 on no match; with set -o pipefail the whole pipe returns non-zero, and under set -e\n        # that would abort the script. The || true here swallows the normal \"no old rule to delete\" case.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n}\n_overlay_snat_cleanup\n\n# Add SNAT rule: rewrite transit source IPs to overlay IP on WG interfaces\n# Use nftables if available, fall back to iptables\nif command -v nft \u003e/dev/null 2\u003e\u00261; then\n    nft -f - \u003c\u003c'NFT_EOF'\ntable inet overlay-snat {\n    chain postrouting {\n        type nat hook postrouting priority srcnat; policy accept;\n        oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.1\n        }\n}\nNFT_EOF\n    echo \"  SNAT (nftables): transit 10.40.0.0/28 → 10.40.16.1 on wg-* interfaces\"\n    elif command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    iptables -t nat -C POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.1 2\u003e/dev/null || \\\n        iptables -t nat -A POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.1\n    echo \"  SNAT (iptables): transit 10.40.0.0/28 → 10.40.16.1 on wg-* interfaces\"\n    fi\n\n# Persist SNAT rule via systemd\ncat \u003e /etc/systemd/system/overlay-snat.service \u003c\u003c 'SNAT_SVC'\n[Unit]\nDescription=Overlay SNAT rule for source address fix\nAfter=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; nft add table inet overlay-snat; nft add chain inet overlay-snat postrouting \"{ type nat hook postrouting priority srcnat; policy accept; }\"; nft add rule inet overlay-snat postrouting oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.1; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.1 2\u003e/dev/null || true; iptables -t nat -A POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.1; fi'\nExecStop=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.1 2\u003e/dev/null || true; fi'\n\n[Install]\nWantedBy=multi-user.target\nSNAT_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-snat.service 2\u003e/dev/null || true\n\necho \"Phase 1 complete.\"\n\n# ============================================================\n# Phase 2: Deploy Configuration\n# ============================================================\n\necho \"=== Phase 2: Deploy Configuration ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Deploy per-peer WireGuard configurations\necho \"Deploying WireGuard per-peer configurations...\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-b.conf\" /etc/wireguard/wg-router-b.conf\nchmod 600 /etc/wireguard/wg-router-b.conf\necho \"  Deployed: /etc/wireguard/wg-router-b.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-c.conf\" /etc/wireguard/wg-router-c.conf\nchmod 600 /etc/wireguard/wg-router-c.conf\necho \"  Deployed: /etc/wireguard/wg-router-c.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-d.conf\" /etc/wireguard/wg-router-d.conf\nchmod 600 /etc/wireguard/wg-router-d.conf\necho \"  Deployed: /etc/wireguard/wg-router-d.conf\"\n# Deploy Babel configuration\necho \"Deploying Babel configuration...\"\ncp \"$SCRIPT_DIR/babel/babeld.conf\" /etc/babel/babeld.conf\necho \"  Deployed: /etc/babel/babeld.conf\"\n# Deploy sysctl configuration\ncp \"$SCRIPT_DIR/sysctl/99-overlay.conf\" /etc/sysctl.d/99-overlay.conf\necho \"  Deployed: /etc/sysctl.d/99-overlay.conf\"\n\necho \"Phase 2 complete.\"\n\n# ============================================================\n# Phase 3: Activate and Verify\n# ============================================================\n\necho \"=== Phase 3: Activate and Verify ===\"\n\n# Apply sysctl\necho \"Applying sysctl settings...\"\nsysctl --system \u003e /dev/null 2\u003e\u00261\necho \"  IPv4 forwarding: $(cat /proc/sys/net/ipv4/ip_forward)\"\n# Start all WireGuard per-peer interfaces\n#\n# D53: the script runs under set -euo pipefail. If one interface's wg-quick up failed without being tolerated,\n# the whole script would abort before configuring babeld, leaving a \"half-started\" node (some tunnels up but the\n# routing daemon unconfigured). So collect each interface's start failure (appended to FAILED_INTERFACES),\n# warn on stderr and continue so babeld and later steps still run; print a failure summary at the end and\n# exit non-zero if any failed (so the deploy tool still sees it), but only after the remaining steps have run.\n# Note the set -e interaction: use the 'if ! wg-quick up ...; then' form, or the non-zero return would abort outright.\necho \"Starting WireGuard interfaces...\"\nFAILED_INTERFACES=\"\"\necho \"  Starting wg-router-b...\"\nif ! wg-quick up \"wg-router-b\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-b; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-b\"\nfi\nsystemctl enable wg-quick@\"wg-router-b\" 2\u003e/dev/null || true\necho \"  Starting wg-router-c...\"\nif ! wg-quick up \"wg-router-c\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-c; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-c\"\nfi\nsystemctl enable wg-quick@\"wg-router-c\" 2\u003e/dev/null || true\necho \"  Starting wg-router-d...\"\nif ! wg-quick up \"wg-router-d\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-d; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-d\"\nfi\nsystemctl enable wg-quick@\"wg-router-d\" 2\u003e/dev/null || true\n# Configure babeld systemd service\necho \"Configuring babeld systemd service...\"\nmkdir -p /etc/systemd/system/babeld.service.d\ncat \u003e /etc/systemd/system/babeld.service.d/override.conf \u003c\u003c 'BABEL_OVERRIDE'\n[Unit]\nDescription=Babel routing daemon (overlay)\nAfter=network.target wg-quick@wg-router-b.service wg-quick@wg-router-c.service wg-quick@wg-router-d.service\nWants=wg-quick@wg-router-b.service wg-quick@wg-router-c.service wg-quick@wg-router-d.service\n\n[Service]\nType=simple\nExecStart=\nExecStart=/usr/sbin/babeld -c /etc/babel/babeld.conf\nRestart=on-failure\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nBABEL_OVERRIDE\nsystemctl daemon-reload\nsystemctl restart babeld\nsystemctl enable babeld\necho \"  Babel daemon started\"\n# Show status\necho \"\"\necho \"============================================================\"\necho \"  Node: \"'router-a'\necho \"  Overlay IP: 10.40.16.1 (on dummy0)\"\necho \"  Role: router\"\necho \"  WireGuard interfaces: wg-router-b wg-router-c wg-router-d \"\necho \"============================================================\"\necho \"\"\necho \"WireGuard status:\"\necho \"--- wg-router-b ---\"\nwg show \"wg-router-b\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-c ---\"\nwg show \"wg-router-c\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-d ---\"\nwg show \"wg-router-d\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"\"\necho \"Babel status:\"\necho \"  Check with: nc ::1 33123 (then type 'dump')\"\necho \"\"\necho \"Installation complete!\"\necho \"Note: If peers are not yet online, connections will establish once they come up.\"\n\n# D53: summarize the WireGuard interface start results. If any failed to start, print the failure list and exit\n# non-zero so the upstream deploy tool can detect it - but this exit happens after babeld config, status display,\n# and the other remaining steps have all completed, so the node is never left in a \"half-started\" state.\nif [ -n \"$FAILED_INTERFACES\" ]; then\n    echo \"\"\n    echo \"WARNING: the following WireGuard interface(s) failed to start:$FAILED_INTERFACES\" \u003e\u00262\n    echo \"         the rest of the installation completed; re-run 'wg-quick up \u003ciface\u003e' to retry.\" \u003e\u00262\n    exit 1\nfi\n",
      "sysctl/99-overlay.conf": "# Sysctl configuration for router-a\n# Generated by Overlay Network Config Orchestrator\n\n#  IPv4 \nnet.ipv4.ip_forward = 1\n\n#  IPv6 （）\n# net.ipv6.conf.all.forwarding = 1\n\n# （Babel ）\nnet.ipv4.conf.all.rp_filter = 0\nnet.ipv4.conf.default.rp_filter = 0\n",
      "wireguard/wg-router-b.conf": "# WireGuard per-peer interface: wg-router-b\n# Node: router-a -\u003e Peer: router-b\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = wNjDSUq700M2tAdIIaZX9nwAz2kA42ylItzJLoPsWGE=\nAddress = 10.40.0.1/32\nTable = off\nListenPort = 51820\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::1/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::1/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-b\n[Peer]\nPublicKey = UdbKbfSzEEMA2muO0b/cJOJu0aALKWpMs6Pfag6kSQY=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-b.example.com:51820\nPersistentKeepalive = 25\n",
      "wireguard/wg-router-c.conf": "# WireGuard per-peer interface: wg-router-c\n# Node: router-a -\u003e Peer: router-c\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = wNjDSUq700M2tAdIIaZX9nwAz2kA42ylItzJLoPsWGE=\nAddress = 10.40.0.3/32\nTable = off\nListenPort = 51821\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::3/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::3/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-c\n[Peer]\nPublicKey = qTNktekeE8O6noZ6jY5tgBDRzCVVdndXBPfRQg4nqzs=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-c.example.com:51820\nPersistentKeepalive = 25\n",
      "wireguard/wg-router-d.conf": "# WireGuard per-peer interface: wg-router-d\n# Node: router-a -\u003e Peer: router-d\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = wNjDSUq700M2tAdIIaZX9nwAz2kA42ylItzJLoPsWGE=\nAddress = 10.40.0.5/32\nTable = off\nListenPort = 51822\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::5/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::5/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-d\n[Peer]\nPublicKey = 0nt/gcGvqeAz7un74VdyGsYOrO/Pg+g6ih3Lcj8dYw4=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-d.example.com:51820\nPersistentKeepalive = 25\n"
    },
    "router-b": {
      "babel/babeld.conf": "# Babel configuration for router-b\n# Generated by Overlay Network Config Orchestrator\n# Role: router\n\nrouter-id f2:f6:a3:b9:34:ec\nlocal-port 33123\nskip-kernel-setup false\n\n# Route redistribution\nredistribute local ip 10.40.16.2/32 allow\nredistribute local ip 10.40.16.0/24 allow\n# Deny all other local routes\nredistribute local deny\n\n# WireGuard tunnel interfaces\ninterface wg-router-a type tunnel hello-interval 4 update-interval 16\ninterface wg-router-c type tunnel hello-interval 4 update-interval 16\n",
      "install.sh": "#!/usr/bin/env bash\n# Install script for node: router-b\n# Generated by Overlay Network Config Orchestrator\n# Platform: ubuntu\n# Role: router\n# Architecture: per-peer WireGuard interfaces\n#\n# Usage:\n#   sudo bash install.sh              # Install / upgrade overlay\n#   sudo bash install.sh --uninstall  # Completely remove overlay\n\nset -euo pipefail\n\nUNINSTALL=0\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --uninstall|-u) UNINSTALL=1 ;;\n    esac\ndone\n\n# ============================================================\n# Uninstall All\n# ============================================================\n\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    # Check root\n    if [ \"$(id -u)\" -ne 0 ]; then\n        echo \"ERROR: This script must be run as root\" \u003e\u00262\n        exit 1\n    fi\n\n    echo \"=== Uninstalling overlay from node: \"'router-b'\" ===\"\n\n# Stop and disable all managed WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-a...\"\n        wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-c...\"\n        wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    # Stop and disable ALL remaining WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261; then\n        for _iface in $(wg show interfaces 2\u003e/dev/null); do\n            echo \"  Stopping WireGuard interface: $_iface...\"\n            wg-quick down \"$_iface\" 2\u003e/dev/null || true\n            systemctl disable \"wg-quick@$_iface\" 2\u003e/dev/null || true\n        done\n    fi\n    rm -f /etc/wireguard/*.conf\n\n# Stop and disable Babel\n    if systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Stopping Babel daemon...\"\n        systemctl stop babeld 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable babeld 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"\n    rm -rf /etc/systemd/system/babeld.service.d\n# Remove sysctl config\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    sysctl --system \u003e /dev/null 2\u003e\u00261\n\n    # Remove overlay SNAT rule and service\n    #\n    # D52: same as _overlay_snat_cleanup - delete each rule whole, matched by wg interface + transit\n    # source pool and ignoring --to-source, so uninstall fully clears even stale rules left by a prior overlay IP change.\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Chained grep -F deletes each matching rule whole, order-independent; see Phase 1's _overlay_snat_cleanup.\n        # grep returns 1 on no match; with set -o pipefail that makes the pipe non-zero and aborts under set -e, so || true guards it.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n    if systemctl is-enabled overlay-snat.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-snat.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-snat.service\n\n    # Remove dummy0 overlay interface and its systemd service\n    if ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Removing dummy0 interface...\"\n        ip link del dummy0 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled overlay-dummy.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-dummy.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-dummy.service\n    systemctl daemon-reload\n\n    echo \"\"\n    echo \"============================================================\"\n    echo \"  Overlay completely removed from node: \"'router-b'\n    echo \"============================================================\"\n    exit 0\nfi\n\n# ============================================================\n# Phase 0: Cleanup Previous Installation\n# ============================================================\n\necho \"=== Phase 0: Cleanup Previous Installation ===\"\n\n# Stop all WireGuard interfaces managed by this overlay\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-a...\"\n    wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-a.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-a.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-c...\"\n    wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-c.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-c.conf\"\nfi\n# Clean up ALL legacy/stale WireGuard interfaces and configs\n# This catches wg0, wg1, wg-overlay, or any other leftover profiles\nif command -v wg \u003e/dev/null 2\u003e\u00261; then\n    for _legacy_iface in $(wg show interfaces 2\u003e/dev/null); do\n        # Skip interfaces managed by this overlay (already handled above)\n        _is_managed=false\n        [ \"$_legacy_iface\" = \"wg-router-a\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-c\" ] \u0026\u0026 _is_managed=true\n        if [ \"$_is_managed\" = \"false\" ]; then\n            echo \"  Stopping legacy WireGuard interface: $_legacy_iface...\"\n            wg-quick down \"$_legacy_iface\" 2\u003e/dev/null || true\n            if systemctl is-enabled \"wg-quick@$_legacy_iface\" \u003e/dev/null 2\u003e\u00261; then\n                systemctl disable \"wg-quick@$_legacy_iface\" 2\u003e/dev/null || true\n            fi\n        fi\n    done\nfi\n# Remove any leftover WireGuard config files not managed by this overlay\nfor _legacy_conf in /etc/wireguard/*.conf; do\n    [ -f \"$_legacy_conf\" ] || continue\n    _legacy_name=\"$(basename \"$_legacy_conf\")\"\n    _is_managed=false\n    [ \"$_legacy_name\" = \"wg-router-a.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-c.conf\" ] \u0026\u0026 _is_managed=true\n    if [ \"$_is_managed\" = \"false\" ]; then\n        rm -f \"$_legacy_conf\"\n        echo \"  Removed legacy config: $_legacy_conf\"\n    fi\ndone\n\n# Stop Babel if running\nif systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n    echo \"  Stopping Babel daemon...\"\n    systemctl stop babeld 2\u003e/dev/null || true\nfi\nif systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable babeld 2\u003e/dev/null || true\nfi\nfor _bcf in \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"; do\n    if [ -f \"$_bcf\" ]; then\n        rm -f \"$_bcf\"\n        echo \"  Removed old Babel config: $_bcf\"\n    fi\ndone\nif [ -f \"/etc/sysctl.d/99-overlay.conf\" ]; then\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    echo \"  Removed old sysctl config\"\nfi\n\necho \"Phase 0 complete.\"\n\n# ============================================================\n# Phase 1: Environment Preparation\n# ============================================================\n\necho \"=== Phase 1: Environment Preparation ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Verify checksums if available\nif [ -f \"$SCRIPT_DIR/checksums.sha256\" ]; then\n    echo \"Verifying file integrity...\"\n    cd \"$SCRIPT_DIR\"\n    if ! sha256sum --status -c checksums.sha256; then\n        echo \"ERROR: Checksum validation failed!\" \u003e\u00262\n        exit 1\n    fi\n    echo \"Checksum validation passed.\"\n    cd - \u003e/dev/null\nfi\n\n# Check root\nif [ \"$(id -u)\" -ne 0 ]; then\n    echo \"ERROR: This script must be run as root\" \u003e\u00262\n    exit 1\nfi\n\n# Detect OS\nif [ -f /etc/os-release ]; then\n    . /etc/os-release\n    OS_ID=\"$ID\"\n    OS_VERSION=\"$VERSION_ID\"\n    echo \"Detected OS: $OS_ID $OS_VERSION\"\nelse\n    echo \"ERROR: Cannot detect OS\" \u003e\u00262\n    exit 1\nfi\n\n# Install dependencies (cross-distro, idempotent)\n#\n# This runs on EVERY controller apply (the daemon re-runs install.sh per generation) and on a\n# manual air-gap run, so it is a fast no-op once the tools exist: each MISSING command is mapped\n# to a package and installed via the detected manager. Supported: apt / dnf / yum / zypper /\n# pacman / apk. Package names match across managers except iproute2 -\u003e iproute on dnf/yum/zypper.\n# An unknown manager with tools still missing fails with an explicit list (no confusing mid-run error).\necho \"Installing dependencies...\"\n\nYAOG_PM=\"\"\nfor _c in apt-get dnf yum zypper pacman apk; do\n    if command -v \"$_c\" \u003e/dev/null 2\u003e\u00261; then YAOG_PM=\"$_c\"; break; fi\ndone\n\n_pm_pkg() { # map a generic package name to this manager's concrete name\n    case \"$1:$YAOG_PM\" in\n        iproute2:dnf|iproute2:yum|iproute2:zypper) echo iproute ;;\n        *) echo \"$1\" ;;\n    esac\n}\n\n_PM_REFRESHED=0\n_pm_install() {\n    local _pkg; _pkg=\"$(_pm_pkg \"$1\")\"\n    if [ \"$_PM_REFRESHED\" -eq 0 ]; then\n        case \"$YAOG_PM\" in\n            apt-get) apt-get update -qq || true ;;\n            apk)     apk update \u003e/dev/null 2\u003e\u00261 || true ;;\n        esac\n        _PM_REFRESHED=1\n    fi\n    case \"$YAOG_PM\" in\n        apt-get) DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \"$_pkg\" ;;\n        dnf)     dnf install -y \"$_pkg\" ;;\n        yum)     yum install -y \"$_pkg\" ;;\n        zypper)  zypper --non-interactive install \"$_pkg\" ;;\n        pacman)  pacman -Sy --noconfirm \"$_pkg\" ;;\n        apk)     apk add --no-progress \"$_pkg\" ;;\n        *)       return 1 ;;\n    esac\n}\n\nYAOG_MISSING=\"\"\nensure_cmd() { # ensure_cmd \u003ccommand\u003e \u003cgeneric-package\u003e: install only if the command is absent\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 \u0026\u0026 return 0\n    if [ -n \"$YAOG_PM\" ]; then\n        echo \"  - installing $2 (provides '$1')\"\n        _pm_install \"$2\" || true\n    fi\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || YAOG_MISSING=\"$YAOG_MISSING $1\"\n}\n\nensure_cmd wg       wireguard-tools\nensure_cmd wg-quick wireguard-tools\nensure_cmd ip       iproute2\nensure_cmd openssl  openssl\n# SNAT uses nft when present, else iptables (+iptables-save, same package) — ensure one exists.\nif ! command -v nft \u003e/dev/null 2\u003e\u00261 \u0026\u0026 ! command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    ensure_cmd iptables iptables\nfi\nensure_cmd babeld babeld\nif [ -n \"$YAOG_MISSING\" ]; then\n    echo \"ERROR: missing required tools:$YAOG_MISSING\" \u003e\u00262\n    echo \"  No supported package manager installed them automatically. Install the equivalents of\" \u003e\u00262\n    echo \"  wireguard-tools (wg, wg-quick), iproute2 (ip), openssl, iptables or nftables, babeld, then re-run.\" \u003e\u00262\n    exit 1\nfi\n\n# WireGuard kernel module: built into Linux \u003e= 5.6; load it (best-effort) on older kernels.\n# If it is genuinely unavailable, wg-quick below surfaces the real error per interface.\nmodprobe wireguard 2\u003e/dev/null || true\n\nmkdir -p /etc/wireguard\nmkdir -p /etc/babel\n# Create dummy0 interface for stable overlay address\nif ! ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n    echo \"Creating dummy0 interface for overlay address...\"\n    ip link add dummy0 type dummy\nfi\nip addr flush dev dummy0 2\u003e/dev/null || true\nip addr add 10.40.16.2/32 dev dummy0\nip link set dummy0 up\necho \"  Overlay address 10.40.16.2/32 assigned to dummy0\"\n\n# Make dummy0 persistent across reboots\ncat \u003e /etc/systemd/system/overlay-dummy.service \u003c\u003c 'DUMMY_SVC'\n[Unit]\nDescription=Overlay dummy interface\nBefore=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/sbin/ip link add dummy0 type dummy\nExecStart=/sbin/ip addr add 10.40.16.2/32 dev dummy0\nExecStart=/sbin/ip link set dummy0 up\nExecStop=/sbin/ip link del dummy0\n\n[Install]\nWantedBy=multi-user.target\nDUMMY_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-dummy.service 2\u003e/dev/null || true\n\n# Fix source address selection for overlay traffic\n# Without this, packets to overlay IPs use the transit IP (10.10.0.x) as source\n# instead of the overlay IP, causing silent failures for plain \"ping \u003coverlay_ip\u003e\"\necho \"Configuring overlay source address fix...\"\n\n# Remove any previous overlay SNAT rules\n#\n# D52: we cannot delete by an exact rule (with --to-source \u003ccurrent overlay IP\u003e): after an overlay IP change a\n# reinstall would leave the old --to-source rule in POSTROUTING, wrongly source-rewriting packets to the old address.\n# Instead: parse iptables-save and delete EVERY POSTROUTING SNAT rule matching the wg interface + transit source\n# pool, whole, regardless of its --to-source. The nft path drops the whole table and has no such problem, so it is left as-is.\n_overlay_snat_cleanup() {\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Delete rule by rule: in the iptables-save output, every POSTROUTING rule whose out interface is wg-+, source is 10.40.0.0/28,\n        # and action is SNAT is turned into a -D delete using its full parameters (ignoring the specific --to-source value).\n        # Use chained grep -F rather than a single order-assuming regex: iptables-save normalizes parameter order\n        # (usually -s before -o), so fixed-string matching is order-independent and needs no escaping of the . and / in the CIDR.\n        # grep returns 1 on no match; with set -o pipefail the whole pipe returns non-zero, and under set -e\n        # that would abort the script. The || true here swallows the normal \"no old rule to delete\" case.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n}\n_overlay_snat_cleanup\n\n# Add SNAT rule: rewrite transit source IPs to overlay IP on WG interfaces\n# Use nftables if available, fall back to iptables\nif command -v nft \u003e/dev/null 2\u003e\u00261; then\n    nft -f - \u003c\u003c'NFT_EOF'\ntable inet overlay-snat {\n    chain postrouting {\n        type nat hook postrouting priority srcnat; policy accept;\n        oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.2\n        }\n}\nNFT_EOF\n    echo \"  SNAT (nftables): transit 10.40.0.0/28 → 10.40.16.2 on wg-* interfaces\"\n    elif command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    iptables -t nat -C POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.2 2\u003e/dev/null || \\\n        iptables -t nat -A POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.2\n    echo \"  SNAT (iptables): transit 10.40.0.0/28 → 10.40.16.2 on wg-* interfaces\"\n    fi\n\n# Persist SNAT rule via systemd\ncat \u003e /etc/systemd/system/overlay-snat.service \u003c\u003c 'SNAT_SVC'\n[Unit]\nDescription=Overlay SNAT rule for source address fix\nAfter=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; nft add table inet overlay-snat; nft add chain inet overlay-snat postrouting \"{ type nat hook postrouting priority srcnat; policy accept; }\"; nft add rule inet overlay-snat postrouting oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.2; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.2 2\u003e/dev/null || true; iptables -t nat -A POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.2; fi'\nExecStop=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.2 2\u003e/dev/null || true; fi'\n\n[Install]\nWantedBy=multi-user.target\nSNAT_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-snat.service 2\u003e/dev/null || true\n\necho \"Phase 1 complete.\"\n\n# ============================================================\n# Phase 2: Deploy Configuration\n# ============================================================\n\necho \"=== Phase 2: Deploy Configuration ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Deploy per-peer WireGuard configurations\necho \"Deploying WireGuard per-peer configurations...\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-a.conf\" /etc/wireguard/wg-router-a.conf\nchmod 600 /etc/wireguard/wg-router-a.conf\necho \"  Deployed: /etc/wireguard/wg-router-a.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-c.conf\" /etc/wireguard/wg-router-c.conf\nchmod 600 /etc/wireguard/wg-router-c.conf\necho \"  Deployed: /etc/wireguard/wg-router-c.conf\"\n# Deploy Babel configuration\necho \"Deploying Babel configuration...\"\ncp \"$SCRIPT_DIR/babel/babeld.conf\" /etc/babel/babeld.conf\necho \"  Deployed: /etc/babel/babeld.conf\"\n# Deploy sysctl configuration\ncp \"$SCRIPT_DIR/sysctl/99-overlay.conf\" /etc/sysctl.d/99-overlay.conf\necho \"  Deployed: /etc/sysctl.d/99-overlay.conf\"\n\necho \"Phase 2 complete.\"\n\n# ============================================================\n# Phase 3: Activate and Verify\n# ============================================================\n\necho \"=== Phase 3: Activate and Verify ===\"\n\n# Apply sysctl\necho \"Applying sysctl settings...\"\nsysctl --system \u003e /dev/null 2\u003e\u00261\necho \"  IPv4 forwarding: $(cat /proc/sys/net/ipv4/ip_forward)\"\n# Start all WireGuard per-peer interfaces\n#\n# D53: the script runs under set -euo pipefail. If one interface's wg-quick up failed without being tolerated,\n# the whole script would abort before configuring babeld, leaving a \"half-started\" node (some tunnels up but the\n# routing daemon unconfigured). So collect each interface's start failure (appended to FAILED_INTERFACES),\n# warn on stderr and continue so babeld and later steps still run; print a failure summary at the end and\n# exit non-zero if any failed (so the deploy tool still sees it), but only after the remaining steps have run.\n# Note the set -e interaction: use the 'if ! wg-quick up ...; then' form, or the non-zero return would abort outright.\necho \"Starting WireGuard interfaces...\"\nFAILED_INTERFACES=\"\"\necho \"  Starting wg-router-a...\"\nif ! wg-quick up \"wg-router-a\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-a; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-a\"\nfi\nsystemctl enable wg-quick@\"wg-router-a\" 2\u003e/dev/null || true\necho \"  Starting wg-router-c...\"\nif ! wg-quick up \"wg-router-c\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-c; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-c\"\nfi\nsystemctl enable wg-quick@\"wg-router-c\" 2\u003e/dev/null || true\n# Configure babeld systemd service\necho \"Configuring babeld systemd service...\"\nmkdir -p /etc/systemd/system/babeld.service.d\ncat \u003e /etc/systemd/system/babeld.service.d/override.conf \u003c\u003c 'BABEL_OVERRIDE'\n[Unit]\nDescription=Babel routing daemon (overlay)\nAfter=network.target wg-quick@wg-router-a.service wg-quick@wg-router-c.service\nWants=wg-quick@wg-router-a.service wg-quick@wg-router-c.service\n\n[Service]\nType=simple\nExecStart=\nExecStart=/usr/sbin/babeld -c /etc/babel/babeld.conf\nRestart=on-failure\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nBABEL_OVERRIDE\nsystemctl daemon-reload\nsystemctl restart babeld\nsystemctl enable babeld\necho \"  Babel daemon started\"\n# Show status\necho \"\"\necho \"============================================================\"\necho \"  Node: \"'router-b'\necho \"  Overlay IP: 10.40.16.2 (on dummy0)\"\necho \"  Role: router\"\necho \"  WireGuard interfaces: wg-router-a wg-router-c \"\necho \"============================================================\"\necho \"\"\necho \"WireGuard status:\"\necho \"--- wg-router-a ---\"\nwg show \"wg-router-a\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-c ---\"\nwg show \"wg-router-c\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"\"\necho \"Babel status:\"\necho \"  Check with: nc ::1 33123 (then type 'dump')\"\necho \"\"\necho \"Installation complete!\"\necho \"Note: If peers are not yet online, connections will establish once they come up.\"\n\n# D53: summarize the WireGuard interface start results. If any failed to start, print the failure list and exit\n# non-zero so the upstream deploy tool can detect it - but this exit happens after babeld config, status display,\n# and the other remaining steps have all completed, so the node is never left in a \"half-started\" state.\nif [ -n \"$FAILED_INTERFACES\" ]; then\n    echo \"\"\n    echo \"WARNING: the following WireGuard interface(s) failed to start:$FAILED_INTERFACES\" \u003e\u00262\n    echo \"         the rest of the installation completed; re-run 'wg-quick up \u003ciface\u003e' to retry.\" \u003e\u00262\n    exit 1\nfi\n",
      "sysctl/99-overlay.conf": "# Sysctl configuration for router-b\n# Generated by Overlay Network Config Orchestrator\n\n#  IPv4 \nnet.ipv4.ip_forward = 1\n\n#  IPv6 （）\n# net.ipv6.conf.all.forwarding = 1\n\n# （Babel ）\nnet.ipv4.conf.all.rp_filter = 0\nnet.ipv4.conf.default.rp_filter = 0\n",
      "wireguard/wg-router-a.conf": "# WireGuard per-peer interface: wg-router-a\n# Node: router-b -\u003e Peer: router-a\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = IOCZgrJw7INyLCywAURMQP7UiCk0hwLUHixbMsyxuV0=\nAddress = 10.40.0.2/32\nTable = off\nListenPort = 51820\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::2/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::2/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-a\n[Peer]\nPublicKey = MTipewRTEKbU2KVIItnBYKbc+W48inpRR2mkLp5M0kA=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-a.example.com:51820\n",
      "wireguard/wg-router-c.conf": "# WireGuard per-peer interface: wg-router-c\n# Node: router-b -\u003e Peer: router-c\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = IOCZgrJw7INyLCywAURMQP7UiCk0hwLUHixbMsyxuV0=\nAddress = 10.40.0.7/32\nTable = off\nListenPort = 51821\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::7/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::7/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-c\n[Peer]\nPublicKey = qTNktekeE8O6noZ6jY5tgBDRzCVVdndXBPfRQg4nqzs=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-c.example.com:51821\nPersistentKeepalive = 25\n"
    },
    "router-c": {
      "babel/babeld.conf": "# Babel configuration for router-c\n# Generated by Overlay Network Config Orchestrator\n# Role: router\n\nrouter-id a6:fa:d2:71:95:a2\nlocal-port 33123\nskip-kernel-setup false\n\n# Route redistribution\nredistribute local ip 10.40.16.3/32 allow\nredistribute local ip 10.40.16.0/24 allow\n# Deny all other local routes\nredistribute local deny\n\n# WireGuard tunnel interfaces\ninterface wg-router-a type tunnel hello-interval 4 update-interval 16\ninterface wg-router-b type tunnel hello-interval 4 update-interval 16\ninterface wg-router-d type tunnel hello-interval 4 update-interval 16\n",
      "install.sh": "#!/usr/bin/env bash\n# Install script for node: router-c\n# Generated by Overlay Network Config Orchestrator\n# Platform: debian\n# Role: router\n# Architecture: per-peer WireGuard interfaces\n#\n# Usage:\n#   sudo bash install.sh              # Install / upgrade overlay\n#   sudo bash install.sh --uninstall  # Completely remove overlay\n\nset -euo pipefail\n\nUNINSTALL=0\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --uninstall|-u) UNINSTALL=1 ;;\n    esac\ndone\n\n# ============================================================\n# Uninstall All\n# ============================================================\n\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    # Check root\n    if [ \"$(id -u)\" -ne 0 ]; then\n        echo \"ERROR: This script must be run as root\" \u003e\u00262\n        exit 1\n    fi\n\n    echo \"=== Uninstalling overlay from node: \"'router-c'\" ===\"\n\n# Stop and disable all managed WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-a...\"\n        wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-b\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-b...\"\n        wg-quick down \"wg-router-b\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-b\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-b\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-b.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-d\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-d...\"\n        wg-quick down \"wg-router-d\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-d\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-d\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-d.conf\"\n    # Stop and disable ALL remaining WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261; then\n        for _iface in $(wg show interfaces 2\u003e/dev/null); do\n            echo \"  Stopping WireGuard interface: $_iface...\"\n            wg-quick down \"$_iface\" 2\u003e/dev/null || true\n            systemctl disable \"wg-quick@$_iface\" 2\u003e/dev/null || true\n        done\n    fi\n    rm -f /etc/wireguard/*.conf\n\n# Stop and disable Babel\n    if systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Stopping Babel daemon...\"\n        systemctl stop babeld 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable babeld 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"\n    rm -rf /etc/systemd/system/babeld.service.d\n# Remove sysctl config\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    sysctl --system \u003e /dev/null 2\u003e\u00261\n\n    # Remove overlay SNAT rule and service\n    #\n    # D52: same as _overlay_snat_cleanup - delete each rule whole, matched by wg interface + transit\n    # source pool and ignoring --to-source, so uninstall fully clears even stale rules left by a prior overlay IP change.\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Chained grep -F deletes each matching rule whole, order-independent; see Phase 1's _overlay_snat_cleanup.\n        # grep returns 1 on no match; with set -o pipefail that makes the pipe non-zero and aborts under set -e, so || true guards it.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n    if systemctl is-enabled overlay-snat.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-snat.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-snat.service\n\n    # Remove dummy0 overlay interface and its systemd service\n    if ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Removing dummy0 interface...\"\n        ip link del dummy0 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled overlay-dummy.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-dummy.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-dummy.service\n    systemctl daemon-reload\n\n    echo \"\"\n    echo \"============================================================\"\n    echo \"  Overlay completely removed from node: \"'router-c'\n    echo \"============================================================\"\n    exit 0\nfi\n\n# ============================================================\n# Phase 0: Cleanup Previous Installation\n# ============================================================\n\necho \"=== Phase 0: Cleanup Previous Installation ===\"\n\n# Stop all WireGuard interfaces managed by this overlay\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-a...\"\n    wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-a.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-a.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-b\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-b...\"\n    wg-quick down \"wg-router-b\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-b\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-b\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-b.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-b.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-b.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-d\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-d...\"\n    wg-quick down \"wg-router-d\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-d\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-d\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-d.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-d.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-d.conf\"\nfi\n# Clean up ALL legacy/stale WireGuard interfaces and configs\n# This catches wg0, wg1, wg-overlay, or any other leftover profiles\nif command -v wg \u003e/dev/null 2\u003e\u00261; then\n    for _legacy_iface in $(wg show interfaces 2\u003e/dev/null); do\n        # Skip interfaces managed by this overlay (already handled above)\n        _is_managed=false\n        [ \"$_legacy_iface\" = \"wg-router-a\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-b\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-d\" ] \u0026\u0026 _is_managed=true\n        if [ \"$_is_managed\" = \"false\" ]; then\n            echo \"  Stopping legacy WireGuard interface: $_legacy_iface...\"\n            wg-quick down \"$_legacy_iface\" 2\u003e/dev/null || true\n            if systemctl is-enabled \"wg-quick@$_legacy_iface\" \u003e/dev/null 2\u003e\u00261; then\n                systemctl disable \"wg-quick@$_legacy_iface\" 2\u003e/dev/null || true\n            fi\n        fi\n    done\nfi\n# Remove any leftover WireGuard config files not managed by this overlay\nfor _legacy_conf in /etc/wireguard/*.conf; do\n    [ -f \"$_legacy_conf\" ] || continue\n    _legacy_name=\"$(basename \"$_legacy_conf\")\"\n    _is_managed=false\n    [ \"$_legacy_name\" = \"wg-router-a.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-b.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-d.conf\" ] \u0026\u0026 _is_managed=true\n    if [ \"$_is_managed\" = \"false\" ]; then\n        rm -f \"$_legacy_conf\"\n        echo \"  Removed legacy config: $_legacy_conf\"\n    fi\ndone\n\n# Stop Babel if running\nif systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n    echo \"  Stopping Babel daemon...\"\n    systemctl stop babeld 2\u003e/dev/null || true\nfi\nif systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable babeld 2\u003e/dev/null || true\nfi\nfor _bcf in \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"; do\n    if [ -f \"$_bcf\" ]; then\n        rm -f \"$_bcf\"\n        echo \"  Removed old Babel config: $_bcf\"\n    fi\ndone\nif [ -f \"/etc/sysctl.d/99-overlay.conf\" ]; then\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    echo \"  Removed old sysctl config\"\nfi\n\necho \"Phase 0 complete.\"\n\n# ============================================================\n# Phase 1: Environment Preparation\n# ============================================================\n\necho \"=== Phase 1: Environment Preparation ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Verify checksums if available\nif [ -f \"$SCRIPT_DIR/checksums.sha256\" ]; then\n    echo \"Verifying file integrity...\"\n    cd \"$SCRIPT_DIR\"\n    if ! sha256sum --status -c checksums.sha256; then\n        echo \"ERROR: Checksum validation failed!\" \u003e\u00262\n        exit 1\n    fi\n    echo \"Checksum validation passed.\"\n    cd - \u003e/dev/null\nfi\n\n# Check root\nif [ \"$(id -u)\" -ne 0 ]; then\n    echo \"ERROR: This script must be run as root\" \u003e\u00262\n    exit 1\nfi\n\n# Detect OS\nif [ -f /etc/os-release ]; then\n    . /etc/os-release\n    OS_ID=\"$ID\"\n    OS_VERSION=\"$VERSION_ID\"\n    echo \"Detected OS: $OS_ID $OS_VERSION\"\nelse\n    echo \"ERROR: Cannot detect OS\" \u003e\u00262\n    exit 1\nfi\n\n# Install dependencies (cross-distro, idempotent)\n#\n# This runs on EVERY controller apply (the daemon re-runs install.sh per generation) and on a\n# manual air-gap run, so it is a fast no-op once the tools exist: each MISSING command is mapped\n# to a package and installed via the detected manager. Supported: apt / dnf / yum / zypper /\n# pacman / apk. Package names match across managers except iproute2 -\u003e iproute on dnf/yum/zypper.\n# An unknown manager with tools still missing fails with an explicit list (no confusing mid-run error).\necho \"Installing dependencies...\"\n\nYAOG_PM=\"\"\nfor _c in apt-get dnf yum zypper pacman apk; do\n    if command -v \"$_c\" \u003e/dev/null 2\u003e\u00261; then YAOG_PM=\"$_c\"; break; fi\ndone\n\n_pm_pkg() { # map a generic package name to this manager's concrete name\n    case \"$1:$YAOG_PM\" in\n        iproute2:dnf|iproute2:yum|iproute2:zypper) echo iproute ;;\n        *) echo \"$1\" ;;\n    esac\n}\n\n_PM_REFRESHED=0\n_pm_install() {\n    local _pkg; _pkg=\"$(_pm_pkg \"$1\")\"\n    if [ \"$_PM_REFRESHED\" -eq 0 ]; then\n        case \"$YAOG_PM\" in\n            apt-get) apt-get update -qq || true ;;\n            apk)     apk update \u003e/dev/null 2\u003e\u00261 || true ;;\n        esac\n        _PM_REFRESHED=1\n    fi\n    case \"$YAOG_PM\" in\n        apt-get) DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \"$_pkg\" ;;\n        dnf)     dnf install -y \"$_pkg\" ;;\n        yum)     yum install -y \"$_pkg\" ;;\n        zypper)  zypper --non-interactive install \"$_pkg\" ;;\n        pacman)  pacman -Sy --noconfirm \"$_pkg\" ;;\n        apk)     apk add --no-progress \"$_pkg\" ;;\n        *)       return 1 ;;\n    esac\n}\n\nYAOG_MISSING=\"\"\nensure_cmd() { # ensure_cmd \u003ccommand\u003e \u003cgeneric-package\u003e: install only if the command is absent\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 \u0026\u0026 return 0\n    if [ -n \"$YAOG_PM\" ]; then\n        echo \"  - installing $2 (provides '$1')\"\n        _pm_install \"$2\" || true\n    fi\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || YAOG_MISSING=\"$YAOG_MISSING $1\"\n}\n\nensure_cmd wg       wireguard-tools\nensure_cmd wg-quick wireguard-tools\nensure_cmd ip       iproute2\nensure_cmd openssl  openssl\n# SNAT uses nft when present, else iptables (+iptables-save, same package) — ensure one exists.\nif ! command -v nft \u003e/dev/null 2\u003e\u00261 \u0026\u0026 ! command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    ensure_cmd iptables iptables\nfi\nensure_cmd babeld babeld\nif [ -n \"$YAOG_MISSING\" ]; then\n    echo \"ERROR: missing required tools:$YAOG_MISSING\" \u003e\u00262\n    echo \"  No supported package manager installed them automatically. Install the equivalents of\" \u003e\u00262\n    echo \"  wireguard-tools (wg, wg-quick), iproute2 (ip), openssl, iptables or nftables, babeld, then re-run.\" \u003e\u00262\n    exit 1\nfi\n\n# WireGuard kernel module: built into Linux \u003e= 5.6; load it (best-effort) on older kernels.\n# If it is genuinely unavailable, wg-quick below surfaces the real error per interface.\nmodprobe wireguard 2\u003e/dev/null || true\n\nmkdir -p /etc/wireguard\nmkdir -p /etc/babel\n# Create dummy0 interface for stable overlay address\nif ! ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n    echo \"Creating dummy0 interface for overlay address...\"\n    ip link add dummy0 type dummy\nfi\nip addr flush dev dummy0 2\u003e/dev/null || true\nip addr add 10.40.16.3/32 dev dummy0\nip link set dummy0 up\necho \"  Overlay address 10.40.16.3/32 assigned to dummy0\"\n\n# Make dummy0 persistent across reboots\ncat \u003e /etc/systemd/system/overlay-dummy.service \u003c\u003c 'DUMMY_SVC'\n[Unit]\nDescription=Overlay dummy interface\nBefore=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/sbin/ip link add dummy0 type dummy\nExecStart=/sbin/ip addr add 10.40.16.3/32 dev dummy0\nExecStart=/sbin/ip link set dummy0 up\nExecStop=/sbin/ip link del dummy0\n\n[Install]\nWantedBy=multi-user.target\nDUMMY_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-dummy.service 2\u003e/dev/null || true\n\n# Fix source address selection for overlay traffic\n# Without this, packets to overlay IPs use the transit IP (10.10.0.x) as source\n# instead of the overlay IP, causing silent failures for plain \"ping \u003coverlay_ip\u003e\"\necho \"Configuring overlay source address fix...\"\n\n# Remove any previous overlay SNAT rules\n#\n# D52: we cannot delete by an exact rule (with --to-source \u003ccurrent overlay IP\u003e): after an overlay IP change a\n# reinstall would leave the old --to-source rule in POSTROUTING, wrongly source-rewriting packets to the old address.\n# Instead: parse iptables-save and delete EVERY POSTROUTING SNAT rule matching the wg interface + transit source\n# pool, whole, regardless of its --to-source. The nft path drops the whole table and has no such problem, so it is left as-is.\n_overlay_snat_cleanup() {\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Delete rule by rule: in the iptables-save output, every POSTROUTING rule whose out interface is wg-+, source is 10.40.0.0/28,\n        # and action is SNAT is turned into a -D delete using its full parameters (ignoring the specific --to-source value).\n        # Use chained grep -F rather than a single order-assuming regex: iptables-save normalizes parameter order\n        # (usually -s before -o), so fixed-string matching is order-independent and needs no escaping of the . and / in the CIDR.\n        # grep returns 1 on no match; with set -o pipefail the whole pipe returns non-zero, and under set -e\n        # that would abort the script. The || true here swallows the normal \"no old rule to delete\" case.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n}\n_overlay_snat_cleanup\n\n# Add SNAT rule: rewrite transit source IPs to overlay IP on WG interfaces\n# Use nftables if available, fall back to iptables\nif command -v nft \u003e/dev/null 2\u003e\u00261; then\n    nft -f - \u003c\u003c'NFT_EOF'\ntable inet overlay-snat {\n    chain postrouting {\n        type nat hook postrouting priority srcnat; policy accept;\n        oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.3\n        }\n}\nNFT_EOF\n    echo \"  SNAT (nftables): transit 10.40.0.0/28 → 10.40.16.3 on wg-* interfaces\"\n    elif command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    iptables -t nat -C POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.3 2\u003e/dev/null || \\\n        iptables -t nat -A POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.3\n    echo \"  SNAT (iptables): transit 10.40.0.0/28 → 10.40.16.3 on wg-* interfaces\"\n    fi\n\n# Persist SNAT rule via systemd\ncat \u003e /etc/systemd/system/overlay-snat.service \u003c\u003c 'SNAT_SVC'\n[Unit]\nDescription=Overlay SNAT rule for source address fix\nAfter=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; nft add table inet overlay-snat; nft add chain inet overlay-snat postrouting \"{ type nat hook postrouting priority srcnat; policy accept; }\"; nft add rule inet overlay-snat postrouting oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.3; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.3 2\u003e/dev/null || true; iptables -t nat -A POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.3; fi'\nExecStop=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.3 2\u003e/dev/null || true; fi'\n\n[Install]\nWantedBy=multi-user.target\nSNAT_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-snat.service 2\u003e/dev/null || true\n\necho \"Phase 1 complete.\"\n\n# ============================================================\n# Phase 2: Deploy Configuration\n# ============================================================\n\necho \"=== Phase 2: Deploy Configuration ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Deploy per-peer WireGuard configurations\necho \"Deploying WireGuard per-peer configurations...\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-a.conf\" /etc/wireguard/wg-router-a.conf\nchmod 600 /etc/wireguard/wg-router-a.conf\necho \"  Deployed: /etc/wireguard/wg-router-a.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-b.conf\" /etc/wireguard/wg-router-b.conf\nchmod 600 /etc/wireguard/wg-router-b.conf\necho \"  Deployed: /etc/wireguard/wg-router-b.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-d.conf\" /etc/wireguard/wg-router-d.conf\nchmod 600 /etc/wireguard/wg-router-d.conf\necho \"  Deployed: /etc/wireguard/wg-router-d.conf\"\n# Deploy Babel configuration\necho \"Deploying Babel configuration...\"\ncp \"$SCRIPT_DIR/babel/babeld.conf\" /etc/babel/babeld.conf\necho \"  Deployed: /etc/babel/babeld.conf\"\n# Deploy sysctl configuration\ncp \"$SCRIPT_DIR/sysctl/99-overlay.conf\" /etc/sysctl.d/99-overlay.conf\necho \"  Deployed: /etc/sysctl.d/99-overlay.conf\"\n\necho \"Phase 2 complete.\"\n\n# ============================================================\n# Phase 3: Activate and Verify\n# ============================================================\n\necho \"=== Phase 3: Activate and Verify ===\"\n\n# Apply sysctl\necho \"Applying sysctl settings...\"\nsysctl --system \u003e /dev/null 2\u003e\u00261\necho \"  IPv4 forwarding: $(cat /proc/sys/net/ipv4/ip_forward)\"\n# Start all WireGuard per-peer interfaces\n#\n# D53: the script runs under set -euo pipefail. If one interface's wg-quick up failed without being tolerated,\n# the whole script would abort before configuring babeld, leaving a \"half-started\" node (some tunnels up but the\n# routing daemon unconfigured). So collect each interface's start failure (appended to FAILED_INTERFACES),\n# warn on stderr and continue so babeld and later steps still run; print a failure summary at the end and\n# exit non-zero if any failed (so the deploy tool still sees it), but only after the remaining steps have run.\n# Note the set -e interaction: use the 'if ! wg-quick up ...; then' form, or the non-zero return would abort outright.\necho \"Starting WireGuard interfaces...\"\nFAILED_INTERFACES=\"\"\necho \"  Starting wg-router-a...\"\nif ! wg-quick up \"wg-router-a\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-a; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-a\"\nfi\nsystemctl enable wg-quick@\"wg-router-a\" 2\u003e/dev/null || true\necho \"  Starting wg-router-b...\"\nif ! wg-quick up \"wg-router-b\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-b; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-b\"\nfi\nsystemctl enable wg-quick@\"wg-router-b\" 2\u003e/dev/null || true\necho \"  Starting wg-router-d...\"\nif ! wg-quick up \"wg-router-d\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-d; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-d\"\nfi\nsystemctl enable wg-quick@\"wg-router-d\" 2\u003e/dev/null || true\n# Configure babeld systemd service\necho \"Configuring babeld systemd service...\"\nmkdir -p /etc/systemd/system/babeld.service.d\ncat \u003e /etc/systemd/system/babeld.service.d/override.conf \u003c\u003c 'BABEL_OVERRIDE'\n[Unit]\nDescription=Babel routing daemon (overlay)\nAfter=network.target wg-quick@wg-router-a.service wg-quick@wg-router-b.service wg-quick@wg-router-d.service\nWants=wg-quick@wg-router-a.service wg-quick@wg-router-b.service wg-quick@wg-router-d.service\n\n[Service]\nType=simple\nExecStart=\nExecStart=/usr/sbin/babeld -c /etc/babel/babeld.conf\nRestart=on-failure\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nBABEL_OVERRIDE\nsystemctl daemon-reload\nsystemctl restart babeld\nsystemctl enable babeld\necho \"  Babel daemon started\"\n# Show status\necho \"\"\necho \"============================================================\"\necho \"  Node: \"'router-c'\necho \"  Overlay IP: 10.40.16.3 (on dummy0)\"\necho \"  Role: router\"\necho \"  WireGuard interfaces: wg-router-a wg-router-b wg-router-d \"\necho \"============================================================\"\necho \"\"\necho \"WireGuard status:\"\necho \"--- wg-router-a ---\"\nwg show \"wg-router-a\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-b ---\"\nwg show \"wg-router-b\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-d ---\"\nwg show \"wg-router-d\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"\"\necho \"Babel status:\"\necho \"  Check with: nc ::1 33123 (then type 'dump')\"\necho \"\"\necho \"Installation complete!\"\necho \"Note: If peers are not yet online, connections will establish once they come up.\"\n\n# D53: summarize the WireGuard interface start results. If any failed to start, print the failure list and exit\n# non-zero so the upstream deploy tool can detect it - but this exit happens after babeld config, status display,\n# and the other remaining steps have all completed, so the node is never left in a \"half-started\" state.\nif [ -n \"$FAILED_INTERFACES\" ]; then\n    echo \"\"\n    echo \"WARNING: the following WireGuard interface(s) failed to start:$FAILED_INTERFACES\" \u003e\u00262\n    echo \"         the rest of the installation completed; re-run 'wg-quick up \u003ciface\u003e' to retry.\" \u003e\u00262\n    exit 1\nfi\n",
      "sysctl/99-overlay.conf": "# Sysctl configuration for router-c\n# Generated by Overlay Network Config Orchestrator\n\n#  IPv4 \nnet.ipv4.ip_forward = 1\n\n#  IPv6 （）\n# net.ipv6.conf.all.forwarding = 1\n\n# （Babel ）\nnet.ipv4.conf.all.rp_filter = 0\nnet.ipv4.conf.default.rp_filter = 0\n",
      "wireguard/wg-router-a.conf": "# WireGuard per-peer interface: wg-router-a\n# Node: router-c -\u003e Peer: router-a\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = kP1c0+Ye0eoXLgUnkm3sQZfgqwvArHtZWevpDNygaUo=\nAddress = 10.40.0.4/32\nTable = off\nListenPort = 51820\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::4/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::4/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-a\n[Peer]\nPublicKey = MTipewRTEKbU2KVIItnBYKbc+W48inpRR2mkLp5M0kA=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-a.example.com:51821\n",
      "wireguard/wg-router-b.conf": "# WireGuard per-peer interface: wg-router-b\n# Node: router-c -\u003e Peer: router-b\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = kP1c0+Ye0eoXLgUnkm3sQZfgqwvArHtZWevpDNygaUo=\nAddress = 10.40.0.8/32\nTable = off\nListenPort = 51821\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::8/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::8/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-b\n[Peer]\nPublicKey = UdbKbfSzEEMA2muO0b/cJOJu0aALKWpMs6Pfag6kSQY=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-b.example.com:51821\n",
      "wireguard/wg-router-d.conf": "# WireGuard per-peer interface: wg-router-d\n# Node: router-c -\u003e Peer: router-d\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = kP1c0+Ye0eoXLgUnkm3sQZfgqwvArHtZWevpDNygaUo=\nAddress = 10.40.0.9/32\nTable = off\nListenPort = 51822\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::9/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::9/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-d\n[Peer]\nPublicKey = 0nt/gcGvqeAz7un74VdyGsYOrO/Pg+g6ih3Lcj8dYw4=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-d.example.com:51821\nPersistentKeepalive = 25\n"
    },
    "router-d": {
      "babel/babeld.conf": "# Babel configuration for router-d\n# Generated by Overlay Network Config Orchestrator\n# Role: router\n\nrouter-id 5a:7e:8d:61:a3:19\nlocal-port 33123\nskip-kernel-setup false\n\n# Route redistribution\nredistribute local ip 10.40.16.4/32 allow\nredistribute local ip 10.40.16.0/24 allow\n# Deny all other local routes\nredistribute local deny\n\n# WireGuard tunnel interfaces\ninterface wg-router-a type tunnel hello-interval 4 update-interval 16\ninterface wg-router-c type tunnel hello-interval 4 update-interval 16\n",
      "install.sh": "#!/usr/bin/env bash\n# Install script for node: router-d\n# Generated by Overlay Network Config Orchestrator\n# Platform: ubuntu\n# Role: router\n# Architecture: per-peer WireGuard interfaces\n#\n# Usage:\n#   sudo bash install.sh              # Install / upgrade overlay\n#   sudo bash install.sh --uninstall  # Completely remove overlay\n\nset -euo pipefail\n\nUNINSTALL=0\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --uninstall|-u) UNINSTALL=1 ;;\n    esac\ndone\n\n# ============================================================\n# Uninstall All\n# ============================================================\n\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    # Check root\n    if [ \"$(id -u)\" -ne 0 ]; then\n        echo \"ERROR: This script must be run as root\" \u003e\u00262\n        exit 1\n    fi\n\n    echo \"=== Uninstalling overlay from node: \"'router-d'\" ===\"\n\n# Stop and disable all managed WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-a...\"\n        wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    if command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n        echo \"  Stopping WireGuard interface: wg-router-c...\"\n        wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    # Stop and disable ALL remaining WireGuard interfaces\n    if command -v wg \u003e/dev/null 2\u003e\u00261; then\n        for _iface in $(wg show interfaces 2\u003e/dev/null); do\n            echo \"  Stopping WireGuard interface: $_iface...\"\n            wg-quick down \"$_iface\" 2\u003e/dev/null || true\n            systemctl disable \"wg-quick@$_iface\" 2\u003e/dev/null || true\n        done\n    fi\n    rm -f /etc/wireguard/*.conf\n\n# Stop and disable Babel\n    if systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Stopping Babel daemon...\"\n        systemctl stop babeld 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable babeld 2\u003e/dev/null || true\n    fi\n    rm -f \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"\n    rm -rf /etc/systemd/system/babeld.service.d\n# Remove sysctl config\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    sysctl --system \u003e /dev/null 2\u003e\u00261\n\n    # Remove overlay SNAT rule and service\n    #\n    # D52: same as _overlay_snat_cleanup - delete each rule whole, matched by wg interface + transit\n    # source pool and ignoring --to-source, so uninstall fully clears even stale rules left by a prior overlay IP change.\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Chained grep -F deletes each matching rule whole, order-independent; see Phase 1's _overlay_snat_cleanup.\n        # grep returns 1 on no match; with set -o pipefail that makes the pipe non-zero and aborts under set -e, so || true guards it.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n    if systemctl is-enabled overlay-snat.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-snat.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-snat.service\n\n    # Remove dummy0 overlay interface and its systemd service\n    if ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n        echo \"  Removing dummy0 interface...\"\n        ip link del dummy0 2\u003e/dev/null || true\n    fi\n    if systemctl is-enabled overlay-dummy.service \u003e/dev/null 2\u003e\u00261; then\n        systemctl disable overlay-dummy.service 2\u003e/dev/null || true\n    fi\n    rm -f /etc/systemd/system/overlay-dummy.service\n    systemctl daemon-reload\n\n    echo \"\"\n    echo \"============================================================\"\n    echo \"  Overlay completely removed from node: \"'router-d'\n    echo \"============================================================\"\n    exit 0\nfi\n\n# ============================================================\n# Phase 0: Cleanup Previous Installation\n# ============================================================\n\necho \"=== Phase 0: Cleanup Previous Installation ===\"\n\n# Stop all WireGuard interfaces managed by this overlay\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-a\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-a...\"\n    wg-quick down \"wg-router-a\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-a\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-a\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-a.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-a.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-a.conf\"\nfi\nif command -v wg \u003e/dev/null 2\u003e\u00261 \u0026\u0026 wg show \"wg-router-c\" \u003e /dev/null 2\u003e\u00261; then\n    echo \"  Stopping WireGuard interface: wg-router-c...\"\n    wg-quick down \"wg-router-c\" 2\u003e/dev/null || true\nfi\nif systemctl is-enabled \"wg-quick@wg-router-c\" \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable \"wg-quick@wg-router-c\" 2\u003e/dev/null || true\nfi\nif [ -f \"/etc/wireguard/wg-router-c.conf\" ]; then\n    rm -f \"/etc/wireguard/wg-router-c.conf\"\n    echo \"  Removed old config: /etc/wireguard/wg-router-c.conf\"\nfi\n# Clean up ALL legacy/stale WireGuard interfaces and configs\n# This catches wg0, wg1, wg-overlay, or any other leftover profiles\nif command -v wg \u003e/dev/null 2\u003e\u00261; then\n    for _legacy_iface in $(wg show interfaces 2\u003e/dev/null); do\n        # Skip interfaces managed by this overlay (already handled above)\n        _is_managed=false\n        [ \"$_legacy_iface\" = \"wg-router-a\" ] \u0026\u0026 _is_managed=true\n        [ \"$_legacy_iface\" = \"wg-router-c\" ] \u0026\u0026 _is_managed=true\n        if [ \"$_is_managed\" = \"false\" ]; then\n            echo \"  Stopping legacy WireGuard interface: $_legacy_iface...\"\n            wg-quick down \"$_legacy_iface\" 2\u003e/dev/null || true\n            if systemctl is-enabled \"wg-quick@$_legacy_iface\" \u003e/dev/null 2\u003e\u00261; then\n                systemctl disable \"wg-quick@$_legacy_iface\" 2\u003e/dev/null || true\n            fi\n        fi\n    done\nfi\n# Remove any leftover WireGuard config files not managed by this overlay\nfor _legacy_conf in /etc/wireguard/*.conf; do\n    [ -f \"$_legacy_conf\" ] || continue\n    _legacy_name=\"$(basename \"$_legacy_conf\")\"\n    _is_managed=false\n    [ \"$_legacy_name\" = \"wg-router-a.conf\" ] \u0026\u0026 _is_managed=true\n    [ \"$_legacy_name\" = \"wg-router-c.conf\" ] \u0026\u0026 _is_managed=true\n    if [ \"$_is_managed\" = \"false\" ]; then\n        rm -f \"$_legacy_conf\"\n        echo \"  Removed legacy config: $_legacy_conf\"\n    fi\ndone\n\n# Stop Babel if running\nif systemctl is-active babeld \u003e/dev/null 2\u003e\u00261; then\n    echo \"  Stopping Babel daemon...\"\n    systemctl stop babeld 2\u003e/dev/null || true\nfi\nif systemctl is-enabled babeld \u003e/dev/null 2\u003e\u00261; then\n    systemctl disable babeld 2\u003e/dev/null || true\nfi\nfor _bcf in \"/etc/babel/babeld.conf\" \"/etc/babeld.conf\"; do\n    if [ -f \"$_bcf\" ]; then\n        rm -f \"$_bcf\"\n        echo \"  Removed old Babel config: $_bcf\"\n    fi\ndone\nif [ -f \"/etc/sysctl.d/99-overlay.conf\" ]; then\n    rm -f \"/etc/sysctl.d/99-overlay.conf\"\n    echo \"  Removed old sysctl config\"\nfi\n\necho \"Phase 0 complete.\"\n\n# ============================================================\n# Phase 1: Environment Preparation\n# ============================================================\n\necho \"=== Phase 1: Environment Preparation ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Verify checksums if available\nif [ -f \"$SCRIPT_DIR/checksums.sha256\" ]; then\n    echo \"Verifying file integrity...\"\n    cd \"$SCRIPT_DIR\"\n    if ! sha256sum --status -c checksums.sha256; then\n        echo \"ERROR: Checksum validation failed!\" \u003e\u00262\n        exit 1\n    fi\n    echo \"Checksum validation passed.\"\n    cd - \u003e/dev/null\nfi\n\n# Check root\nif [ \"$(id -u)\" -ne 0 ]; then\n    echo \"ERROR: This script must be run as root\" \u003e\u00262\n    exit 1\nfi\n\n# Detect OS\nif [ -f /etc/os-release ]; then\n    . /etc/os-release\n    OS_ID=\"$ID\"\n    OS_VERSION=\"$VERSION_ID\"\n    echo \"Detected OS: $OS_ID $OS_VERSION\"\nelse\n    echo \"ERROR: Cannot detect OS\" \u003e\u00262\n    exit 1\nfi\n\n# Install dependencies (cross-distro, idempotent)\n#\n# This runs on EVERY controller apply (the daemon re-runs install.sh per generation) and on a\n# manual air-gap run, so it is a fast no-op once the tools exist: each MISSING command is mapped\n# to a package and installed via the detected manager. Supported: apt / dnf / yum / zypper /\n# pacman / apk. Package names match across managers except iproute2 -\u003e iproute on dnf/yum/zypper.\n# An unknown manager with tools still missing fails with an explicit list (no confusing mid-run error).\necho \"Installing dependencies...\"\n\nYAOG_PM=\"\"\nfor _c in apt-get dnf yum zypper pacman apk; do\n    if command -v \"$_c\" \u003e/dev/null 2\u003e\u00261; then YAOG_PM=\"$_c\"; break; fi\ndone\n\n_pm_pkg() { # map a generic package name to this manager's concrete name\n    case \"$1:$YAOG_PM\" in\n        iproute2:dnf|iproute2:yum|iproute2:zypper) echo iproute ;;\n        *) echo \"$1\" ;;\n    esac\n}\n\n_PM_REFRESHED=0\n_pm_install() {\n    local _pkg; _pkg=\"$(_pm_pkg \"$1\")\"\n    if [ \"$_PM_REFRESHED\" -eq 0 ]; then\n        case \"$YAOG_PM\" in\n            apt-get) apt-get update -qq || true ;;\n            apk)     apk update \u003e/dev/null 2\u003e\u00261 || true ;;\n        esac\n        _PM_REFRESHED=1\n    fi\n    case \"$YAOG_PM\" in\n        apt-get) DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \"$_pkg\" ;;\n        dnf)     dnf install -y \"$_pkg\" ;;\n        yum)     yum install -y \"$_pkg\" ;;\n        zypper)  zypper --non-interactive install \"$_pkg\" ;;\n        pacman)  pacman -Sy --noconfirm \"$_pkg\" ;;\n        apk)     apk add --no-progress \"$_pkg\" ;;\n        *)       return 1 ;;\n    esac\n}\n\nYAOG_MISSING=\"\"\nensure_cmd() { # ensure_cmd \u003ccommand\u003e \u003cgeneric-package\u003e: install only if the command is absent\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 \u0026\u0026 return 0\n    if [ -n \"$YAOG_PM\" ]; then\n        echo \"  - installing $2 (provides '$1')\"\n        _pm_install \"$2\" || true\n    fi\n    command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || YAOG_MISSING=\"$YAOG_MISSING $1\"\n}\n\nensure_cmd wg       wireguard-tools\nensure_cmd wg-quick wireguard-tools\nensure_cmd ip       iproute2\nensure_cmd openssl  openssl\n# SNAT uses nft when present, else iptables (+iptables-save, same package) — ensure one exists.\nif ! command -v nft \u003e/dev/null 2\u003e\u00261 \u0026\u0026 ! command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    ensure_cmd iptables iptables\nfi\nensure_cmd babeld babeld\nif [ -n \"$YAOG_MISSING\" ]; then\n    echo \"ERROR: missing required tools:$YAOG_MISSING\" \u003e\u00262\n    echo \"  No supported package manager installed them automatically. Install the equivalents of\" \u003e\u00262\n    echo \"  wireguard-tools (wg, wg-quick), iproute2 (ip), openssl, iptables or nftables, babeld, then re-run.\" \u003e\u00262\n    exit 1\nfi\n\n# WireGuard kernel module: built into Linux \u003e= 5.6; load it (best-effort) on older kernels.\n# If it is genuinely unavailable, wg-quick below surfaces the real error per interface.\nmodprobe wireguard 2\u003e/dev/null || true\n\nmkdir -p /etc/wireguard\nmkdir -p /etc/babel\n# Create dummy0 interface for stable overlay address\nif ! ip link show dummy0 \u003e/dev/null 2\u003e\u00261; then\n    echo \"Creating dummy0 interface for overlay address...\"\n    ip link add dummy0 type dummy\nfi\nip addr flush dev dummy0 2\u003e/dev/null || true\nip addr add 10.40.16.4/32 dev dummy0\nip link set dummy0 up\necho \"  Overlay address 10.40.16.4/32 assigned to dummy0\"\n\n# Make dummy0 persistent across reboots\ncat \u003e /etc/systemd/system/overlay-dummy.service \u003c\u003c 'DUMMY_SVC'\n[Unit]\nDescription=Overlay dummy interface\nBefore=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/sbin/ip link add dummy0 type dummy\nExecStart=/sbin/ip addr add 10.40.16.4/32 dev dummy0\nExecStart=/sbin/ip link set dummy0 up\nExecStop=/sbin/ip link del dummy0\n\n[Install]\nWantedBy=multi-user.target\nDUMMY_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-dummy.service 2\u003e/dev/null || true\n\n# Fix source address selection for overlay traffic\n# Without this, packets to overlay IPs use the transit IP (10.10.0.x) as source\n# instead of the overlay IP, causing silent failures for plain \"ping \u003coverlay_ip\u003e\"\necho \"Configuring overlay source address fix...\"\n\n# Remove any previous overlay SNAT rules\n#\n# D52: we cannot delete by an exact rule (with --to-source \u003ccurrent overlay IP\u003e): after an overlay IP change a\n# reinstall would leave the old --to-source rule in POSTROUTING, wrongly source-rewriting packets to the old address.\n# Instead: parse iptables-save and delete EVERY POSTROUTING SNAT rule matching the wg interface + transit source\n# pool, whole, regardless of its --to-source. The nft path drops the whole table and has no such problem, so it is left as-is.\n_overlay_snat_cleanup() {\n    if command -v nft \u003e/dev/null 2\u003e\u00261; then\n        nft delete table inet overlay-snat 2\u003e/dev/null || true\n    fi\n    if command -v iptables \u003e/dev/null 2\u003e\u00261 \u0026\u0026 command -v iptables-save \u003e/dev/null 2\u003e\u00261; then\n        # Delete rule by rule: in the iptables-save output, every POSTROUTING rule whose out interface is wg-+, source is 10.40.0.0/28,\n        # and action is SNAT is turned into a -D delete using its full parameters (ignoring the specific --to-source value).\n        # Use chained grep -F rather than a single order-assuming regex: iptables-save normalizes parameter order\n        # (usually -s before -o), so fixed-string matching is order-independent and needs no escaping of the . and / in the CIDR.\n        # grep returns 1 on no match; with set -o pipefail the whole pipe returns non-zero, and under set -e\n        # that would abort the script. The || true here swallows the normal \"no old rule to delete\" case.\n        iptables-save -t nat 2\u003e/dev/null \\\n            | grep -E '^-A POSTROUTING ' \\\n            | grep -F -- '-j SNAT' \\\n            | grep -F -- '-o wg-+' \\\n            | grep -F -- '-s 10.40.0.0/28' \\\n            | while IFS= read -r _snat_rule; do\n                _snat_del=\"${_snat_rule/#-A/-D}\"\n                # shellcheck disable=SC2086\n                iptables -t nat $_snat_del 2\u003e/dev/null || true\n            done || true\n        fi\n}\n_overlay_snat_cleanup\n\n# Add SNAT rule: rewrite transit source IPs to overlay IP on WG interfaces\n# Use nftables if available, fall back to iptables\nif command -v nft \u003e/dev/null 2\u003e\u00261; then\n    nft -f - \u003c\u003c'NFT_EOF'\ntable inet overlay-snat {\n    chain postrouting {\n        type nat hook postrouting priority srcnat; policy accept;\n        oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.4\n        }\n}\nNFT_EOF\n    echo \"  SNAT (nftables): transit 10.40.0.0/28 → 10.40.16.4 on wg-* interfaces\"\n    elif command -v iptables \u003e/dev/null 2\u003e\u00261; then\n    iptables -t nat -C POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.4 2\u003e/dev/null || \\\n        iptables -t nat -A POSTROUTING -o \"wg-+\" -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.4\n    echo \"  SNAT (iptables): transit 10.40.0.0/28 → 10.40.16.4 on wg-* interfaces\"\n    fi\n\n# Persist SNAT rule via systemd\ncat \u003e /etc/systemd/system/overlay-snat.service \u003c\u003c 'SNAT_SVC'\n[Unit]\nDescription=Overlay SNAT rule for source address fix\nAfter=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; nft add table inet overlay-snat; nft add chain inet overlay-snat postrouting \"{ type nat hook postrouting priority srcnat; policy accept; }\"; nft add rule inet overlay-snat postrouting oifname \"wg-*\" ip saddr 10.40.0.0/28 snat to 10.40.16.4; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.4 2\u003e/dev/null || true; iptables -t nat -A POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.4; fi'\nExecStop=/bin/bash -c 'if command -v nft \u003e/dev/null 2\u003e\u00261; then nft delete table inet overlay-snat 2\u003e/dev/null || true; else iptables -t nat -D POSTROUTING -o wg-+ -s 10.40.0.0/28 -j SNAT --to-source 10.40.16.4 2\u003e/dev/null || true; fi'\n\n[Install]\nWantedBy=multi-user.target\nSNAT_SVC\nsystemctl daemon-reload\nsystemctl enable overlay-snat.service 2\u003e/dev/null || true\n\necho \"Phase 1 complete.\"\n\n# ============================================================\n# Phase 2: Deploy Configuration\n# ============================================================\n\necho \"=== Phase 2: Deploy Configuration ===\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" \u0026\u0026 pwd)\"\n\n# Deploy per-peer WireGuard configurations\necho \"Deploying WireGuard per-peer configurations...\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-a.conf\" /etc/wireguard/wg-router-a.conf\nchmod 600 /etc/wireguard/wg-router-a.conf\necho \"  Deployed: /etc/wireguard/wg-router-a.conf\"\ncp \"$SCRIPT_DIR/wireguard/wg-router-c.conf\" /etc/wireguard/wg-router-c.conf\nchmod 600 /etc/wireguard/wg-router-c.conf\necho \"  Deployed: /etc/wireguard/wg-router-c.conf\"\n# Deploy Babel configuration\necho \"Deploying Babel configuration...\"\ncp \"$SCRIPT_DIR/babel/babeld.conf\" /etc/babel/babeld.conf\necho \"  Deployed: /etc/babel/babeld.conf\"\n# Deploy sysctl configuration\ncp \"$SCRIPT_DIR/sysctl/99-overlay.conf\" /etc/sysctl.d/99-overlay.conf\necho \"  Deployed: /etc/sysctl.d/99-overlay.conf\"\n\necho \"Phase 2 complete.\"\n\n# ============================================================\n# Phase 3: Activate and Verify\n# ============================================================\n\necho \"=== Phase 3: Activate and Verify ===\"\n\n# Apply sysctl\necho \"Applying sysctl settings...\"\nsysctl --system \u003e /dev/null 2\u003e\u00261\necho \"  IPv4 forwarding: $(cat /proc/sys/net/ipv4/ip_forward)\"\n# Start all WireGuard per-peer interfaces\n#\n# D53: the script runs under set -euo pipefail. If one interface's wg-quick up failed without being tolerated,\n# the whole script would abort before configuring babeld, leaving a \"half-started\" node (some tunnels up but the\n# routing daemon unconfigured). So collect each interface's start failure (appended to FAILED_INTERFACES),\n# warn on stderr and continue so babeld and later steps still run; print a failure summary at the end and\n# exit non-zero if any failed (so the deploy tool still sees it), but only after the remaining steps have run.\n# Note the set -e interaction: use the 'if ! wg-quick up ...; then' form, or the non-zero return would abort outright.\necho \"Starting WireGuard interfaces...\"\nFAILED_INTERFACES=\"\"\necho \"  Starting wg-router-a...\"\nif ! wg-quick up \"wg-router-a\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-a; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-a\"\nfi\nsystemctl enable wg-quick@\"wg-router-a\" 2\u003e/dev/null || true\necho \"  Starting wg-router-c...\"\nif ! wg-quick up \"wg-router-c\"; then\n    echo \"WARNING: failed to bring up WireGuard interface wg-router-c; continuing with remaining setup\" \u003e\u00262\n    FAILED_INTERFACES=\"$FAILED_INTERFACES wg-router-c\"\nfi\nsystemctl enable wg-quick@\"wg-router-c\" 2\u003e/dev/null || true\n# Configure babeld systemd service\necho \"Configuring babeld systemd service...\"\nmkdir -p /etc/systemd/system/babeld.service.d\ncat \u003e /etc/systemd/system/babeld.service.d/override.conf \u003c\u003c 'BABEL_OVERRIDE'\n[Unit]\nDescription=Babel routing daemon (overlay)\nAfter=network.target wg-quick@wg-router-a.service wg-quick@wg-router-c.service\nWants=wg-quick@wg-router-a.service wg-quick@wg-router-c.service\n\n[Service]\nType=simple\nExecStart=\nExecStart=/usr/sbin/babeld -c /etc/babel/babeld.conf\nRestart=on-failure\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nBABEL_OVERRIDE\nsystemctl daemon-reload\nsystemctl restart babeld\nsystemctl enable babeld\necho \"  Babel daemon started\"\n# Show status\necho \"\"\necho \"============================================================\"\necho \"  Node: \"'router-d'\necho \"  Overlay IP: 10.40.16.4 (on dummy0)\"\necho \"  Role: router\"\necho \"  WireGuard interfaces: wg-router-a wg-router-c \"\necho \"============================================================\"\necho \"\"\necho \"WireGuard status:\"\necho \"--- wg-router-a ---\"\nwg show \"wg-router-a\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"--- wg-router-c ---\"\nwg show \"wg-router-c\" 2\u003e/dev/null || echo \"  (not yet connected)\"\necho \"\"\necho \"Babel status:\"\necho \"  Check with: nc ::1 33123 (then type 'dump')\"\necho \"\"\necho \"Installation complete!\"\necho \"Note: If peers are not yet online, connections will establish once they come up.\"\n\n# D53: summarize the WireGuard interface start results. If any failed to start, print the failure list and exit\n# non-zero so the upstream deploy tool can detect it - but this exit happens after babeld config, status display,\n# and the other remaining steps have all completed, so the node is never left in a \"half-started\" state.\nif [ -n \"$FAILED_INTERFACES\" ]; then\n    echo \"\"\n    echo \"WARNING: the following WireGuard interface(s) failed to start:$FAILED_INTERFACES\" \u003e\u00262\n    echo \"         the rest of the installation completed; re-run 'wg-quick up \u003ciface\u003e' to retry.\" \u003e\u00262\n    exit 1\nfi\n",
      "sysctl/99-overlay.conf": "# Sysctl configuration for router-d\n# Generated by Overlay Network Config Orchestrator\n\n#  IPv4 \nnet.ipv4.ip_forward = 1\n\n#  IPv6 （）\n# net.ipv6.conf.all.forwarding = 1\n\n# （Babel ）\nnet.ipv4.conf.all.rp_filter = 0\nnet.ipv4.conf.default.rp_filter = 0\n",
      "wireguard/wg-router-a.conf": "# WireGuard per-peer interface: wg-router-a\n# Node: router-d -\u003e Peer: router-a\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = 4IKjycH3Yax2flKO8NOqS7J3y2KtlVd73ajBgxsgzE4=\nAddress = 10.40.0.6/32\nTable = off\nListenPort = 51820\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::6/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::6/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-a\n[Peer]\nPublicKey = MTipewRTEKbU2KVIItnBYKbc+W48inpRR2mkLp5M0kA=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-a.example.com:51822\n",
      "wireguard/wg-router-c.conf": "# WireGuard per-peer interface: wg-router-c\n# Node: router-d -\u003e Peer: router-c\n# Generated by Overlay Network Config Orchestrator\n\n[Interface]\nPrivateKey = 4IKjycH3Yax2flKO8NOqS7J3y2KtlVd73ajBgxsgzE4=\nAddress = 10.40.0.10/32\nTable = off\nListenPort = 51821\n\n# Add IPv6 link-local for Babel\nPostUp = ip -6 addr add fe80::a/64 dev %i 2\u003e/dev/null || true\nPostDown = ip -6 addr del fe80::a/64 dev %i 2\u003e/dev/null || true\n\n# Peer: router-c\n[Peer]\nPublicKey = qTNktekeE8O6noZ6jY5tgBDRzCVVdndXBPfRQg4nqzs=\nAllowedIPs = 0.0.0.0/0, ::/0\nEndpoint = router-c.example.com:51822\n"
    }
  },
  "deploy": {
    "deploy-all.ps1": "# Auto-deploy script for project: Transit CIDR Non /24\n# Generated by Overlay Network Config Orchestrator\n#\n# Usage:\n#   .\\deploy-all.ps1 -ArtifactsZip \u003cpath-to-artifacts.zip\u003e [-Clean]    Deploy overlay\n#   .\\deploy-all.ps1 -Uninstall                                         Remove overlay\n#\n# Options:\n#   -Clean      Remove ALL existing WireGuard interfaces (wg*) before deploying.\n#   -Uninstall  Completely remove the overlay from all nodes via SSH.\n#               No artifacts ZIP needed.\n\nparam(\n    [string]$ArtifactsZip,\n\n    [switch]$Clean,\n\n    [switch]$Uninstall\n)\n\n$ErrorActionPreference = \"Continue\"\n\nif (-not $Uninstall -and [string]::IsNullOrEmpty($ArtifactsZip)) {\n    Write-Host \"Usage: .\\deploy-all.ps1 -ArtifactsZip \u003cpath\u003e [-Clean]\"\n    Write-Host \"       .\\deploy-all.ps1 -Uninstall\"\n    exit 1\n}\n\n$WorkDir = $null\n\nif (-not [string]::IsNullOrEmpty($ArtifactsZip)) {\n    if (-not (Test-Path $ArtifactsZip)) {\n        Write-Error \"File not found: $ArtifactsZip\"\n        exit 1\n    }\n\n    # Extract to temp\n    $WorkDir = Join-Path ([System.IO.Path]::GetTempPath()) (\"overlay-deploy-\" + [System.Guid]::NewGuid().ToString(\"N\").Substring(0,8))\n    New-Item -ItemType Directory -Path $WorkDir -Force | Out-Null\n}\n\n# Clean script sent to remote via stdin (single-quoted — no PS expansion)\n$CleanScript = 'for iface in $(ip -o link show type wireguard 2\u003e/dev/null | awk -F: ''{print $2}'' | tr -d \" \"); do wg-quick down \"$iface\" 2\u003e/dev/null || ip link del \"$iface\" 2\u003e/dev/null || true; done; rm -f /etc/wireguard/wg*.conf; nft delete table inet overlay-snat 2\u003e/dev/null || true; _snat_ip=$(ip -4 addr show dummy0 2\u003e/dev/null | grep -oP ''inet \\K[^/]+'' || true); [ -n \"$_snat_ip\" ] \u0026\u0026 iptables -t nat -D POSTROUTING -o ''wg-+'' -s 10.10.0.0/24 -j SNAT --to-source \"$_snat_ip\" 2\u003e/dev/null || true; systemctl disable overlay-snat.service 2\u003e/dev/null || true; rm -f /etc/systemd/system/overlay-snat.service'\n\ntry {\n    if ($WorkDir) {\n        Write-Host \"Extracting artifacts...\"\n        Expand-Archive -Path $ArtifactsZip -DestinationPath $WorkDir -Force\n    }\n\n    if ($Uninstall) {\n        Write-Host \"\"\n        Write-Host \"*** UNINSTALL MODE — overlay will be removed from all nodes ***\" -ForegroundColor Yellow\n        Write-Host \"\"\n    }\n\n    $Failed = 0\n    $Skipped = 0\n    $Success = 0\n\n    Write-Host \"\"\n    Write-Host (\"=== \" + \"router-a\" + \": SKIPPED (no SSH details configured) ===\")\n    $Skipped++\n\n    Write-Host \"\"\n    Write-Host (\"=== \" + \"router-b\" + \": SKIPPED (no SSH details configured) ===\")\n    $Skipped++\n\n    Write-Host \"\"\n    Write-Host (\"=== \" + \"router-c\" + \": SKIPPED (no SSH details configured) ===\")\n    $Skipped++\n\n    Write-Host \"\"\n    Write-Host (\"=== \" + \"router-d\" + \": SKIPPED (no SSH details configured) ===\")\n    $Skipped++\n\n    Write-Host \"\"\n    Write-Host \"============================================================\"\n    if ($Uninstall) {\n        Write-Host \"  Uninstall Summary\"\n    } else {\n        Write-Host \"  Deploy Summary\"\n    }\n    Write-Host \"  Success: $Success  Skipped: $Skipped  Failed: $Failed\"\n    Write-Host \"============================================================\"\n\n    if ($Failed -gt 0) {\n        exit 1\n    }\n} finally {\n    if ($WorkDir) { Remove-Item -Recurse -Force $WorkDir -ErrorAction SilentlyContinue }\n}\n",
    "deploy-all.sh": "#!/usr/bin/env bash\n# Auto-deploy script for project: Transit CIDR Non /24\n# Generated by Overlay Network Config Orchestrator\n#\n# Usage:\n#   bash deploy-all.sh [--clean] \u003cpath-to-artifacts.zip\u003e    Deploy overlay\n#   bash deploy-all.sh --uninstall \u003cpath-to-artifacts.zip\u003e   Remove overlay from all nodes\n#\n# Options:\n#   --clean      Remove ALL existing WireGuard interfaces (wg*) before deploying.\n#                Use this when switching from a single-interface (wg0) layout to\n#                per-peer interfaces, or vice versa.\n#   --uninstall  Completely remove the overlay from all nodes via SSH.\n#                Stops all WireGuard interfaces, removes configs, stops Babel,\n#                removes dummy0, and reloads systemd. No installer upload needed.\n#\n# This script SSHs into each configured node. Nodes without SSH details are skipped.\n# SSH failures are caught per-node and do not abort the entire run.\n\nset -uo pipefail\n\nCLEAN=0\nUNINSTALL=0\nARTIFACTS_ZIP=\"\"\n\nfor arg in \"$@\"; do\n    case \"$arg\" in\n        --clean) CLEAN=1 ;;\n        --uninstall|-u) UNINSTALL=1 ;;\n        *) ARTIFACTS_ZIP=\"$arg\" ;;\n    esac\ndone\n\nif [ \"$UNINSTALL\" -eq 0 ] \u0026\u0026 [ -z \"$ARTIFACTS_ZIP\" ]; then\n    echo \"Usage: $0 [--clean] \u003cpath-to-artifacts.zip\u003e\"\n    echo \"       $0 --uninstall\"\n    echo \"\"\n    echo \"Options:\"\n    echo \"  --clean      Remove all existing WireGuard interfaces before deploying\"\n    echo \"  --uninstall  Completely remove the overlay from all nodes\"\n    echo \"\"\n    echo \"Download the artifacts ZIP from the web UI (Export Artifacts button),\"\n    echo \"then run this script pointing at the downloaded file.\"\n    exit 1\nfi\n\nWORKDIR=\"\"\nif [ -n \"$ARTIFACTS_ZIP\" ]; then\n    if [ ! -f \"$ARTIFACTS_ZIP\" ]; then\n        echo \"ERROR: File not found: $ARTIFACTS_ZIP\" \u003e\u00262\n        exit 1\n    fi\n\n    # Extract to a temp directory\n    WORKDIR=\"$(mktemp -d -t overlay-deploy-XXXXXX)\"\n    cleanup() { rm -rf \"$WORKDIR\"; }\n    trap cleanup EXIT\n\n    echo \"Extracting artifacts...\"\n    unzip -q \"$ARTIFACTS_ZIP\" -d \"$WORKDIR\"\nfi\n\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    echo \"\"\n    echo \"*** UNINSTALL MODE — overlay will be removed from all nodes ***\"\n    echo \"\"\nfi\n\nFAILED=0\nSKIPPED=0\nSUCCESS=0\n\n# --- Node: router-a ---\necho \"\"\necho \"=== \"'router-a'\": SKIPPED (no SSH details configured) ===\"\nSKIPPED=$((SKIPPED + 1))\n\n# --- Node: router-b ---\necho \"\"\necho \"=== \"'router-b'\": SKIPPED (no SSH details configured) ===\"\nSKIPPED=$((SKIPPED + 1))\n\n# --- Node: router-c ---\necho \"\"\necho \"=== \"'router-c'\": SKIPPED (no SSH details configured) ===\"\nSKIPPED=$((SKIPPED + 1))\n\n# --- Node: router-d ---\necho \"\"\necho \"=== \"'router-d'\": SKIPPED (no SSH details configured) ===\"\nSKIPPED=$((SKIPPED + 1))\n\necho \"\"\necho \"============================================================\"\nif [ \"$UNINSTALL\" -eq 1 ]; then\n    echo \"  Uninstall Summary\"\nelse\n    echo \"  Deploy Summary\"\nfi\necho \"  Success: $SUCCESS  Skipped: $SKIPPED  Failed: $FAILED\"\necho \"============================================================\"\n\nif [ \"$FAILED\" -gt 0 ]; then\n    exit 1\nfi\n"
  },
