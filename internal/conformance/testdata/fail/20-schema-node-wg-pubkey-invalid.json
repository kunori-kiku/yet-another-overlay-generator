    ],
    "nodes": [
      { "id": "router-a", "name": "router-a", "platform": "debian", "role": "router", "domain_id": "d1",
        "overlay_ip": "10.55.0.10", "wireguard_public_key": "not-a-valid-curve25519-key",
        "capabilities": { "can_accept_inbound": true, "can_forward": true, "has_public_ip": true },
        "public_endpoints": [ { "id": "ra-ep", "host": "router-a.example.com", "port": 51820 } ] },
