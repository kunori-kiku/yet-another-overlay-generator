# Auto-deploy script for project: Deploy Golden
# Generated by Overlay Network Config Orchestrator
#
# Usage:
#   .\deploy-all.ps1 -ArtifactsZip <path-to-artifacts.zip> [-Clean]    Deploy overlay
#   .\deploy-all.ps1 -Uninstall                                         Remove overlay
#
# Options:
#   -Clean      Remove ALL existing WireGuard interfaces (wg*) before deploying.
#   -Uninstall  Completely remove the overlay from all nodes via SSH.
#               No artifacts ZIP needed.

param(
    [string]$ArtifactsZip,

    [switch]$Clean,

    [switch]$Uninstall
)

$ErrorActionPreference = "Continue"

if (-not $Uninstall -and [string]::IsNullOrEmpty($ArtifactsZip)) {
    Write-Host "Usage: .\deploy-all.ps1 -ArtifactsZip <path> [-Clean]"
    Write-Host "       .\deploy-all.ps1 -Uninstall"
    exit 1
}

$WorkDir = $null

if (-not [string]::IsNullOrEmpty($ArtifactsZip)) {
    if (-not (Test-Path $ArtifactsZip)) {
        Write-Error "File not found: $ArtifactsZip"
        exit 1
    }

    # Extract to temp
    $WorkDir = Join-Path ([System.IO.Path]::GetTempPath()) ("overlay-deploy-" + [System.Guid]::NewGuid().ToString("N").Substring(0,8))
    New-Item -ItemType Directory -Path $WorkDir -Force | Out-Null
}

# Clean script sent to remote via stdin (single-quoted — no PS expansion)
$CleanScript = 'for iface in $(ip -o link show type wireguard 2>/dev/null | awk -F: ''{print $2}'' | tr -d " "); do wg-quick down "$iface" 2>/dev/null || ip link del "$iface" 2>/dev/null || true; done; rm -f /etc/wireguard/wg*.conf; nft delete table inet overlay-snat 2>/dev/null || true; iptables-save -t nat 2>/dev/null | grep -E ''^-A POSTROUTING '' | grep -F -- ''-j SNAT'' | grep -F -- ''-o wg-+'' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true; systemctl disable overlay-snat.service 2>/dev/null || true; rm -f /etc/systemd/system/overlay-snat.service'

try {
    if ($WorkDir) {
        Write-Host "Extracting artifacts..."
        Expand-Archive -Path $ArtifactsZip -DestinationPath $WorkDir -Force
    }

    if ($Uninstall) {
        Write-Host ""
        Write-Host "*** UNINSTALL MODE — overlay will be removed from all nodes ***" -ForegroundColor Yellow
        Write-Host ""
    }

    $Failed = 0
    $Skipped = 0
    $Success = 0

    Write-Host ""
    if ($Uninstall) {
        Write-Host ("=== Uninstalling from " + "alpha" + " (" + "root@alpha.example.com" + ") ===")
        $sshTest = & ssh -p 22 "root@alpha.example.com" "echo ok" 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Host ("  ERROR: SSH connection to " + "alpha" + " failed.") -ForegroundColor Red
            $Failed++
        } else {
            $uninstallScript = @'
set -uo pipefail
_mimic_egress_if="$(ip route show default 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')"
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''alpha''...'
wg-quick down wg-beta 2>/dev/null || true
systemctl disable wg-quick@wg-beta 2>/dev/null || true
rm -f /etc/wireguard/wg-beta.conf
wg-quick down wg-gamma 2>/dev/null || true
systemctl disable wg-quick@wg-gamma 2>/dev/null || true
rm -f /etc/wireguard/wg-gamma.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''alpha''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''alpha''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''alpha''...'
systemctl daemon-reload
echo 'Overlay removed from ''alpha''.'
'@
            $uninstallScript | & ssh -p 22 "root@alpha.example.com" sudo bash -s
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: Uninstall failed on " + "alpha" + ".") -ForegroundColor Red
                $Failed++
            } else {
                Write-Host ("  SUCCESS: " + "alpha" + " uninstalled.")
                $Success++
            }
        }
    } else {
        Write-Host ("=== Deploying to " + "alpha" + " (" + "root@alpha.example.com" + ") ===")
        $Installer = Join-Path $WorkDir "alpha.install.sh"
        if (-not (Test-Path $Installer)) {
            Write-Warning "Installer alpha.install.sh not found in archive, skipping."
            $Skipped++
        } else {
            $sshTest = & ssh -p 22 "root@alpha.example.com" "echo ok" 2>&1
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: SSH connection to " + "alpha" + " failed.") -ForegroundColor Red
                $Failed++
            } else {
                if ($Clean) {
                    Write-Host ("  Cleaning existing WireGuard interfaces on " + "alpha" + "...")
                    $CleanScript | & ssh -p 22 "root@alpha.example.com" sudo bash -s 2>$null
                }

                & scp -P 22 $Installer "root@alpha.example.com:/tmp/alpha-install.sh"
                if ($LASTEXITCODE -ne 0) {
                    Write-Host ("  ERROR: SCP upload to " + "alpha" + " failed.") -ForegroundColor Red
                    $Failed++
                } else {
                    & ssh -p 22 "root@alpha.example.com" "sudo bash /tmp/alpha-install.sh && rm -f /tmp/alpha-install.sh"
                    if ($LASTEXITCODE -ne 0) {
                        Write-Host ("  ERROR: Installation script failed on " + "alpha" + " (exit code: $LASTEXITCODE).") -ForegroundColor Red
                        $Failed++
                    } else {
                        Write-Host ("  SUCCESS: " + "alpha" + " deployed.")
                        $Success++
                    }
                }
            }
        }
    }

    Write-Host ""
    if ($Uninstall) {
        Write-Host ("=== Uninstalling from " + "beta" + " (" + "beta-alias" + ") ===")
        $sshTest = & ssh "beta-alias" "echo ok" 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Host ("  ERROR: SSH connection to " + "beta" + " failed.") -ForegroundColor Red
            $Failed++
        } else {
            $uninstallScript = @'
set -uo pipefail
_mimic_egress_if='wan0'
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''beta''...'
wg-quick down wg-alpha 2>/dev/null || true
systemctl disable wg-quick@wg-alpha 2>/dev/null || true
rm -f /etc/wireguard/wg-alpha.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''beta''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''beta''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''beta''...'
systemctl daemon-reload
echo 'Overlay removed from ''beta''.'
'@
            $uninstallScript | & ssh "beta-alias" sudo bash -s
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: Uninstall failed on " + "beta" + ".") -ForegroundColor Red
                $Failed++
            } else {
                Write-Host ("  SUCCESS: " + "beta" + " uninstalled.")
                $Success++
            }
        }
    } else {
        Write-Host ("=== Deploying to " + "beta" + " (" + "beta-alias" + ") ===")
        $Installer = Join-Path $WorkDir "beta.install.sh"
        if (-not (Test-Path $Installer)) {
            Write-Warning "Installer beta.install.sh not found in archive, skipping."
            $Skipped++
        } else {
            $sshTest = & ssh "beta-alias" "echo ok" 2>&1
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: SSH connection to " + "beta" + " failed.") -ForegroundColor Red
                $Failed++
            } else {
                if ($Clean) {
                    Write-Host ("  Cleaning existing WireGuard interfaces on " + "beta" + "...")
                    $CleanScript | & ssh "beta-alias" sudo bash -s 2>$null
                }

                & scp $Installer "beta-alias:/tmp/beta-install.sh"
                if ($LASTEXITCODE -ne 0) {
                    Write-Host ("  ERROR: SCP upload to " + "beta" + " failed.") -ForegroundColor Red
                    $Failed++
                } else {
                    & ssh "beta-alias" "sudo bash /tmp/beta-install.sh && rm -f /tmp/beta-install.sh"
                    if ($LASTEXITCODE -ne 0) {
                        Write-Host ("  ERROR: Installation script failed on " + "beta" + " (exit code: $LASTEXITCODE).") -ForegroundColor Red
                        $Failed++
                    } else {
                        Write-Host ("  SUCCESS: " + "beta" + " deployed.")
                        $Success++
                    }
                }
            }
        }
    }

    Write-Host ""
    if ($Uninstall) {
        Write-Host ("=== Uninstalling from " + "gamma" + " (" + "deploy@10.0.0.9" + ") ===")
        $sshTest = & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" "echo ok" 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Host ("  ERROR: SSH connection to " + "gamma" + " failed.") -ForegroundColor Red
            $Failed++
        } else {
            $uninstallScript = @'
set -uo pipefail
echo '[Stage 1/4] Stopping WireGuard interfaces on ''gamma''...'
wg-quick down wg0 2>/dev/null || true
systemctl disable wg-quick@wg0 2>/dev/null || true
rm -f /etc/wireguard/wg0.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 3/4] Removing overlay network configuration on ''gamma''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
echo '[Stage 4/4] Reloading systemd on ''gamma''...'
systemctl daemon-reload
echo 'Overlay removed from ''gamma''.'
'@
            $uninstallScript | & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" sudo bash -s
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: Uninstall failed on " + "gamma" + ".") -ForegroundColor Red
                $Failed++
            } else {
                Write-Host ("  SUCCESS: " + "gamma" + " uninstalled.")
                $Success++
            }
        }
    } else {
        Write-Host ("=== Deploying to " + "gamma" + " (" + "deploy@10.0.0.9" + ") ===")
        $Installer = Join-Path $WorkDir "gamma.install.sh"
        if (-not (Test-Path $Installer)) {
            Write-Warning "Installer gamma.install.sh not found in archive, skipping."
            $Skipped++
        } else {
            $sshTest = & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" "echo ok" 2>&1
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: SSH connection to " + "gamma" + " failed.") -ForegroundColor Red
                $Failed++
            } else {
                if ($Clean) {
                    Write-Host ("  Cleaning existing WireGuard interfaces on " + "gamma" + "...")
                    $CleanScript | & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" sudo bash -s 2>$null
                }

                & scp -P 2222 -i "/home/op/keys/id_ed25519" $Installer "deploy@10.0.0.9:/tmp/gamma-install.sh"
                if ($LASTEXITCODE -ne 0) {
                    Write-Host ("  ERROR: SCP upload to " + "gamma" + " failed.") -ForegroundColor Red
                    $Failed++
                } else {
                    & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" "sudo bash /tmp/gamma-install.sh && rm -f /tmp/gamma-install.sh"
                    if ($LASTEXITCODE -ne 0) {
                        Write-Host ("  ERROR: Installation script failed on " + "gamma" + " (exit code: $LASTEXITCODE).") -ForegroundColor Red
                        $Failed++
                    } else {
                        Write-Host ("  SUCCESS: " + "gamma" + " deployed.")
                        $Success++
                    }
                }
            }
        }
    }

    Write-Host ""
    Write-Host ("=== " + "delta" + ": SKIPPED (no SSH details configured) ===")
    $Skipped++

    Write-Host ""
    Write-Host "============================================================"
    if ($Uninstall) {
        Write-Host "  Uninstall Summary"
    } else {
        Write-Host "  Deploy Summary"
    }
    Write-Host "  Success: $Success  Skipped: $Skipped  Failed: $Failed"
    Write-Host "============================================================"

    if ($Failed -gt 0) {
        exit 1
    }
} finally {
    if ($WorkDir) { Remove-Item -Recurse -Force $WorkDir -ErrorAction SilentlyContinue }
}
