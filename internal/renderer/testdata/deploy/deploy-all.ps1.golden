                        & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" $UninstallCommand
                        if ($LASTEXITCODE -ne 0) {
                            Write-Host ("  ERROR: Uninstall failed on " + "gamma" + ".") -ForegroundColor Red
                            $Failed++
