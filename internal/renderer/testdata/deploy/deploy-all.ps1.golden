    } else {
        Write-Host ("=== Deploying to " + "gamma" + " (" + "deploy@10.0.0.9" + ") ===")
        $BundleDir = Join-Path $WorkDir "gamma"
        $InstallScript = Join-Path $BundleDir "install.sh"
        $Checksums = Join-Path $BundleDir "checksums.sha256"
        if (-not (Test-Path -LiteralPath $BundleDir -PathType Container) -or
            -not (Test-Path -LiteralPath $InstallScript -PathType Leaf) -or
            -not (Test-Path -LiteralPath $Checksums -PathType Leaf)) {
            Write-Warning ("Complete bundle directory for " + "gamma" + " not found in archive, skipping.")
            $Skipped++
        } else {
            $sshTest = & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" "echo ok" 2>&1
            if ($LASTEXITCODE -ne 0) {
                Write-Host ("  ERROR: SSH connection to " + "gamma" + " failed.") -ForegroundColor Red
                $Failed++
            } else {
                $RemoteOutput = & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" "mktemp -d -- '/tmp/yaog-gamma-XXXXXXXX'" 2>&1
                $RemoteDir = [string]($RemoteOutput | Select-Object -Last 1)
                $RemoteDir = $RemoteDir.Trim()
                $RemotePrefix = "/tmp/yaog-gamma-"
                $RemotePattern = '^' + [regex]::Escape($RemotePrefix) + '[A-Za-z0-9]{8}$'
                if ($LASTEXITCODE -ne 0 -or [string]::IsNullOrEmpty($RemoteDir) -or
                    $RemoteDir -notmatch $RemotePattern) {
                    Write-Host ("  ERROR: Remote staging directory for " + "gamma" + " was not created safely.") -ForegroundColor Red
                    $Failed++
                } else {
                    $ScpDestination = "deploy@10.0.0.9" + ":" + $RemoteDir + "/bundle"
                    & scp -P 2222 -i "/home/op/keys/id_ed25519" -r $BundleDir $ScpDestination
                    if ($LASTEXITCODE -ne 0) {
                        Write-Host ("  ERROR: SCP upload to " + "gamma" + " failed.") -ForegroundColor Red
                        $CleanupCommand = "rm -rf -- '$RemoteDir'"
                        & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" $CleanupCommand 2>$null | Out-Null
                        $Failed++
                    } else {
                        $RemoteCommand = "sudo bash '$RemoteDir/bundle/install.sh'" + $InstallArgs + '; _yaog_rc=$?; rm -rf -- ' + "'$RemoteDir'" + ' || { [ $_yaog_rc -ne 0 ] || _yaog_rc=1; }; exit $_yaog_rc'
                        & ssh -p 2222 -i "/home/op/keys/id_ed25519" "deploy@10.0.0.9" $RemoteCommand
                        if ($LASTEXITCODE -ne 0) {
                            Write-Host ("  ERROR: Installation script failed on " + "gamma" + " (exit code: $LASTEXITCODE).") -ForegroundColor Red
                            $Failed++
                        } else {
                            Write-Host ("  SUCCESS: " + "gamma" + " deployed.")
                            $Success++
                        }
                    }
                }
            }
        }
    }

    Write-Host ""
    Write-Host ("=== " + "delta" + ": SKIPPED (no SSH details configured) ===")
    $Skipped++

    Write-Host ""
    Write-Host "============================================================"
    if ($Uninstall) {
        Write-Host "  Uninstall Summary"
    } else {
        Write-Host "  Deploy Summary"
    }
    Write-Host "  Success: $Success  Skipped: $Skipped  Failed: $Failed"
    Write-Host "============================================================"

    if ($Failed -gt 0) {
        exit 1
    }
} finally {
    if ($WorkDir) { Remove-Item -Recurse -Force $WorkDir -ErrorAction SilentlyContinue }
}
