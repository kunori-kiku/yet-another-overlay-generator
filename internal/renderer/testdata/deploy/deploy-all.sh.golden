#!/usr/bin/env bash
# Auto-deploy script for project: Deploy Golden
# Generated by Overlay Network Config Orchestrator
#
# Usage:
#   bash deploy-all.sh [--clean] <path-to-artifacts.zip>    Deploy overlay
#   bash deploy-all.sh --uninstall <path-to-artifacts.zip>   Remove overlay from all nodes
#
# Options:
#   --clean      Remove ALL existing WireGuard interfaces (wg*) before deploying.
#                Use this when switching from a single-interface (wg0) layout to
#                per-peer interfaces, or vice versa.
#   --uninstall  Completely remove the overlay from all nodes via SSH.
#                Stops all WireGuard interfaces, removes configs, stops Babel,
#                removes dummy0, and reloads systemd. No installer upload needed.
#
# This script SSHs into each configured node. Nodes without SSH details are skipped.
# SSH failures are caught per-node and do not abort the entire run.

set -uo pipefail

CLEAN=0
UNINSTALL=0
ARTIFACTS_ZIP=""

for arg in "$@"; do
    case "$arg" in
        --clean) CLEAN=1 ;;
        --uninstall|-u) UNINSTALL=1 ;;
        *) ARTIFACTS_ZIP="$arg" ;;
    esac
done

if [ "$UNINSTALL" -eq 0 ] && [ -z "$ARTIFACTS_ZIP" ]; then
    echo "Usage: $0 [--clean] <path-to-artifacts.zip>"
    echo "       $0 --uninstall"
    echo ""
    echo "Options:"
    echo "  --clean      Remove all existing WireGuard interfaces before deploying"
    echo "  --uninstall  Completely remove the overlay from all nodes"
    echo ""
    echo "Download the artifacts ZIP from the web UI (Export Artifacts button),"
    echo "then run this script pointing at the downloaded file."
    exit 1
fi

WORKDIR=""
if [ -n "$ARTIFACTS_ZIP" ]; then
    if [ ! -f "$ARTIFACTS_ZIP" ]; then
        echo "ERROR: File not found: $ARTIFACTS_ZIP" >&2
        exit 1
    fi

    # Extract to a temp directory
    WORKDIR="$(mktemp -d -t overlay-deploy-XXXXXX)"
    cleanup() { rm -rf "$WORKDIR"; }
    trap cleanup EXIT

    echo "Extracting artifacts..."
    unzip -q "$ARTIFACTS_ZIP" -d "$WORKDIR"
fi

if [ "$UNINSTALL" -eq 1 ]; then
    echo ""
    echo "*** UNINSTALL MODE — overlay will be removed from all nodes ***"
    echo ""
fi

FAILED=0
SKIPPED=0
SUCCESS=0

# --- Node: alpha ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'alpha'" ("'root@alpha.example.com'") ==="
    if ! ssh -p 22 'root@alpha.example.com' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'alpha'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh -p 22 'root@alpha.example.com' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
_mimic_egress_if="$(ip route show default 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')"
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''alpha''...'
wg-quick down wg-beta 2>/dev/null || true
systemctl disable wg-quick@wg-beta 2>/dev/null || true
rm -f /etc/wireguard/wg-beta.conf
wg-quick down wg-gamma 2>/dev/null || true
systemctl disable wg-quick@wg-gamma 2>/dev/null || true
rm -f /etc/wireguard/wg-gamma.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''alpha''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''alpha''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''alpha''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''alpha''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'alpha'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'alpha'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'alpha'" ("'root@alpha.example.com'") ==="
    INSTALLER="$WORKDIR/alpha.install.sh"
    if [ ! -f "$INSTALLER" ]; then
        echo "  WARNING: Installer alpha.install.sh not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        # Test SSH connectivity first
        if ! ssh -p 22 'root@alpha.example.com' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'alpha'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            # Clean previous WireGuard configs if requested
            if [ "$CLEAN" -eq 1 ]; then
                echo "  Cleaning existing WireGuard interfaces on "'alpha'"..."
                ssh -p 22 'root@alpha.example.com' sudo bash -s <<'CLEAN_EOF' 2>/dev/null || true
for iface in $(ip -o link show type wireguard 2>/dev/null | awk -F: '{print $2}' | tr -d ' '); do
    wg-quick down "$iface" 2>/dev/null || ip link del "$iface" 2>/dev/null || true
done
rm -f /etc/wireguard/wg*.conf
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
CLEAN_EOF
            fi

            if scp -P 22 "$INSTALLER" 'root@alpha.example.com':/tmp/alpha-install.sh; then
                if ssh -p 22 'root@alpha.example.com' "sudo bash /tmp/alpha-install.sh && rm -f /tmp/alpha-install.sh"; then
                    echo "  SUCCESS: "'alpha'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'alpha'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            else
                echo "  ERROR: SCP upload to "'alpha'" failed." >&2
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: beta ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'beta'" ("'beta-alias'") ==="
    if ! ssh 'beta-alias' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'beta'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh 'beta-alias' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
_mimic_egress_if='wan0'
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''beta''...'
wg-quick down wg-alpha 2>/dev/null || true
systemctl disable wg-quick@wg-alpha 2>/dev/null || true
rm -f /etc/wireguard/wg-alpha.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''beta''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''beta''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''beta''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''beta''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'beta'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'beta'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'beta'" ("'beta-alias'") ==="
    INSTALLER="$WORKDIR/beta.install.sh"
    if [ ! -f "$INSTALLER" ]; then
        echo "  WARNING: Installer beta.install.sh not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        # Test SSH connectivity first
        if ! ssh 'beta-alias' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'beta'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            # Clean previous WireGuard configs if requested
            if [ "$CLEAN" -eq 1 ]; then
                echo "  Cleaning existing WireGuard interfaces on "'beta'"..."
                ssh 'beta-alias' sudo bash -s <<'CLEAN_EOF' 2>/dev/null || true
for iface in $(ip -o link show type wireguard 2>/dev/null | awk -F: '{print $2}' | tr -d ' '); do
    wg-quick down "$iface" 2>/dev/null || ip link del "$iface" 2>/dev/null || true
done
rm -f /etc/wireguard/wg*.conf
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
CLEAN_EOF
            fi

            if scp "$INSTALLER" 'beta-alias':/tmp/beta-install.sh; then
                if ssh 'beta-alias' "sudo bash /tmp/beta-install.sh && rm -f /tmp/beta-install.sh"; then
                    echo "  SUCCESS: "'beta'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'beta'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            else
                echo "  ERROR: SCP upload to "'beta'" failed." >&2
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: gamma ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'gamma'" ("'deploy@10.0.0.9'") ==="
    if ! ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'gamma'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
echo '[Stage 1/4] Stopping WireGuard interfaces on ''gamma''...'
wg-quick down wg0 2>/dev/null || true
systemctl disable wg-quick@wg0 2>/dev/null || true
rm -f /etc/wireguard/wg0.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 3/4] Removing overlay network configuration on ''gamma''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
echo '[Stage 4/4] Reloading systemd on ''gamma''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''gamma''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'gamma'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'gamma'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'gamma'" ("'deploy@10.0.0.9'") ==="
    INSTALLER="$WORKDIR/gamma.install.sh"
    if [ ! -f "$INSTALLER" ]; then
        echo "  WARNING: Installer gamma.install.sh not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        # Test SSH connectivity first
        if ! ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'gamma'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            # Clean previous WireGuard configs if requested
            if [ "$CLEAN" -eq 1 ]; then
                echo "  Cleaning existing WireGuard interfaces on "'gamma'"..."
                ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' sudo bash -s <<'CLEAN_EOF' 2>/dev/null || true
for iface in $(ip -o link show type wireguard 2>/dev/null | awk -F: '{print $2}' | tr -d ' '); do
    wg-quick down "$iface" 2>/dev/null || ip link del "$iface" 2>/dev/null || true
done
rm -f /etc/wireguard/wg*.conf
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
CLEAN_EOF
            fi

            if scp -P 2222 -i '/home/op/keys/id_ed25519' "$INSTALLER" 'deploy@10.0.0.9':/tmp/gamma-install.sh; then
                if ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "sudo bash /tmp/gamma-install.sh && rm -f /tmp/gamma-install.sh"; then
                    echo "  SUCCESS: "'gamma'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'gamma'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            else
                echo "  ERROR: SCP upload to "'gamma'" failed." >&2
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: delta ---
echo ""
echo "=== "'delta'": SKIPPED (no SSH details configured) ==="
SKIPPED=$((SKIPPED + 1))

echo ""
echo "============================================================"
if [ "$UNINSTALL" -eq 1 ]; then
    echo "  Uninstall Summary"
else
    echo "  Deploy Summary"
fi
echo "  Success: $SUCCESS  Skipped: $SKIPPED  Failed: $FAILED"
echo "============================================================"

if [ "$FAILED" -gt 0 ]; then
    exit 1
fi
