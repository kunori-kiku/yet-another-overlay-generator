#!/usr/bin/env bash
# Auto-deploy script for project: Deploy Golden
# Generated by Overlay Network Config Orchestrator
#
# Usage:
#   bash deploy-all.sh [--clean] <path-to-artifacts.zip>    Deploy overlay
#   bash deploy-all.sh --uninstall <path-to-artifacts.zip>   Remove overlay from all nodes
#
# Options:
#   --clean      Remove ALL existing WireGuard interfaces (wg*) before deploying.
#                Use this when switching from a single-interface (wg0) layout to
#                per-peer interfaces, or vice versa.
#   --uninstall  Completely remove the overlay from all nodes via SSH.
#                Stops all WireGuard interfaces, removes configs, stops Babel,
#                removes dummy0, and reloads systemd. No installer upload needed.
#
# This script SSHs into each configured node. Nodes without SSH details are skipped.
# SSH failures are caught per-node and do not abort the entire run.

set -uo pipefail

CLEAN=0
UNINSTALL=0
ARTIFACTS_ZIP=""

for arg in "$@"; do
    case "$arg" in
        --clean) CLEAN=1 ;;
        --uninstall|-u) UNINSTALL=1 ;;
        *) ARTIFACTS_ZIP="$arg" ;;
    esac
done

# Destructive layout cleanup is delegated to the candidate install.sh as --clean. That script
# verifies its signature/checksums first; deploy-all must never mutate the remote host beforehand.
INSTALL_ARGS=""
if [ "$CLEAN" -eq 1 ]; then
    INSTALL_ARGS=" --clean"
fi

if [ "$UNINSTALL" -eq 0 ] && [ -z "$ARTIFACTS_ZIP" ]; then
    echo "Usage: $0 [--clean] <path-to-artifacts.zip>"
    echo "       $0 --uninstall"
    echo ""
    echo "Options:"
    echo "  --clean      Remove all existing WireGuard interfaces before deploying"
    echo "  --uninstall  Completely remove the overlay from all nodes"
    echo ""
    echo "Download the artifacts ZIP from the web UI (Export Artifacts button),"
    echo "then run this script pointing at the downloaded file."
    exit 1
fi

WORKDIR=""
if [ -n "$ARTIFACTS_ZIP" ]; then
    if [ ! -f "$ARTIFACTS_ZIP" ]; then
        echo "ERROR: File not found: $ARTIFACTS_ZIP" >&2
        exit 1
    fi

    # Bound both the transport and the central-directory expansion before extraction. These
    # limits match the manual kit's intentionally small configuration-bundle envelope.
    ARCHIVE_MAX_BYTES=33554432
    ARCHIVE_MAX_ENTRIES=512
    ARCHIVE_MAX_FILE_BYTES=4194304
    ARCHIVE_MAX_EXPANDED_BYTES=16777216
    ARCHIVE_BYTES="$(wc -c < "$ARTIFACTS_ZIP" | tr -d '[:space:]')"
    case "$ARCHIVE_BYTES" in
        ''|*[!0-9]*) echo "ERROR: Could not determine artifacts ZIP size" >&2; exit 1 ;;
    esac
    if [ "$ARCHIVE_BYTES" -gt "$ARCHIVE_MAX_BYTES" ]; then
        echo "ERROR: Artifacts ZIP exceeds the 32 MiB archive limit" >&2
        exit 1
    fi

    # Extract to a temp directory
    WORKDIR="$(mktemp -d -t overlay-deploy-XXXXXX)"
    cleanup() { rm -rf "$WORKDIR"; }
    trap cleanup EXIT

    # Reject path aliases, traversal, duplicate names, and Unix special/symlink entries before
    # extraction. SCP -r follows symlinks, so accepting one could copy arbitrary operator-host files.
    ZIP_LIST="$WORKDIR/.zip-entries"
    if ! unzip -Z1 "$ARTIFACTS_ZIP" > "$ZIP_LIST"; then
        echo "ERROR: Failed to inspect artifacts ZIP: $ARTIFACTS_ZIP" >&2
        exit 1
    fi
    ZIP_ENTRY_COUNT="$(wc -l < "$ZIP_LIST" | tr -d '[:space:]')"
    case "$ZIP_ENTRY_COUNT" in
        ''|*[!0-9]*) echo "ERROR: Could not determine artifacts ZIP entry count" >&2; exit 1 ;;
    esac
    if [ "$ZIP_ENTRY_COUNT" -gt "$ARCHIVE_MAX_ENTRIES" ]; then
        echo "ERROR: Artifacts ZIP exceeds the 512-entry limit" >&2
        exit 1
    fi
    # Info-ZIP's long listing reports each accepted regular/directory entry with its uncompressed
    # byte length in column 4. Require the stats count to match -Z1 so an unknown entry type cannot
    # evade the size accounting, then bound every file and the aggregate expanded payload.
    if ! unzip -Z -l "$ARTIFACTS_ZIP" | LC_ALL=C awk \
        -v expected="$ZIP_ENTRY_COUNT" \
        -v max_file="$ARCHIVE_MAX_FILE_BYTES" \
        -v max_total="$ARCHIVE_MAX_EXPANDED_BYTES" '
            $1 ~ /^[-d]/ {
                if ($4 !~ /^[0-9]+$/) bad=1
                count++
                size=$4+0
                if (size > max_file) bad=1
                total += size
                if (total > max_total) bad=1
            }
            END { exit (bad || count != expected) ? 1 : 0 }
        '; then
        echo "ERROR: Artifacts ZIP has an unknown entry type or exceeds the 4 MiB per-file / 16 MiB expanded limits" >&2
        exit 1
    fi
    if LC_ALL=C awk '{ key=tolower($0); if (seen[key]++) duplicate=1 } END { exit duplicate ? 0 : 1 }' "$ZIP_LIST"; then
        echo "ERROR: Artifacts ZIP contains duplicate or case-colliding entry names" >&2
        exit 1
    fi
    while IFS= read -r ZIP_ENTRY || [ -n "$ZIP_ENTRY" ]; do
        ZIP_ENTRY_CHECK="${ZIP_ENTRY%/}"
        case "$ZIP_ENTRY_CHECK" in
            ""|/*|*\\*|*:* )
                echo "ERROR: Unsafe artifacts ZIP entry: $ZIP_ENTRY" >&2
                exit 1
                ;;
        esac
        case "/$ZIP_ENTRY_CHECK/" in
            *"/../"*|*"/./"*|*"//"*)
                echo "ERROR: Non-canonical artifacts ZIP entry: $ZIP_ENTRY" >&2
                exit 1
                ;;
        esac
        if printf '%s' "$ZIP_ENTRY_CHECK" | LC_ALL=C grep -q '[[:cntrl:]]'; then
            echo "ERROR: Artifacts ZIP entry contains a control character" >&2
            exit 1
        fi
    done < "$ZIP_LIST"
    if unzip -Z -l "$ARTIFACTS_ZIP" | grep -Eq '^[lbcps]'; then
        echo "ERROR: Artifacts ZIP contains a symlink or special-file entry" >&2
        exit 1
    fi
    rm -f "$ZIP_LIST"

    echo "Extracting artifacts..."
    if ! unzip -q "$ARTIFACTS_ZIP" -d "$WORKDIR"; then
        echo "ERROR: Failed to extract artifacts ZIP: $ARTIFACTS_ZIP" >&2
        exit 1
    fi
    if find "$WORKDIR" \( -type l -o \( ! -type f ! -type d \) \) -print -quit | grep -q .; then
        echo "ERROR: Extracted artifacts contain a symlink or special file" >&2
        exit 1
    fi
fi

if [ "$UNINSTALL" -eq 1 ]; then
    echo ""
    echo "*** UNINSTALL MODE — overlay will be removed from all nodes ***"
    echo ""
fi

FAILED=0
SKIPPED=0
SUCCESS=0

# --- Node: alpha ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'alpha'" ("'root@alpha.example.com'") ==="
    if ! ssh -p 22 'root@alpha.example.com' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'alpha'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh -p 22 'root@alpha.example.com' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
_mimic_egress_if="$(ip route show default 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')"
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''alpha''...'
wg-quick down wg-beta 2>/dev/null || true
systemctl disable wg-quick@wg-beta 2>/dev/null || true
rm -f /etc/wireguard/wg-beta.conf
wg-quick down wg-gamma 2>/dev/null || true
systemctl disable wg-quick@wg-gamma 2>/dev/null || true
rm -f /etc/wireguard/wg-gamma.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''alpha''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''alpha''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''alpha''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''alpha''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'alpha'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'alpha'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'alpha'" ("'root@alpha.example.com'") ==="
    BUNDLE_DIR=""
    if [ -d "$WORKDIR"/'alpha' ]; then
        BUNDLE_DIR="$WORKDIR"/'alpha'
    fi
    if [ -z "$BUNDLE_DIR" ] || [ ! -f "$BUNDLE_DIR/install.sh" ] || [ ! -f "$BUNDLE_DIR/checksums.sha256" ]; then
        echo "  WARNING: Complete bundle directory for "'alpha'" not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        if ! ssh -p 22 'root@alpha.example.com' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'alpha'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            REMOTE_DIR="$(ssh -p 22 'root@alpha.example.com' "mktemp -d -- '/tmp/yaog-alpha-XXXXXXXX'")"
            REMOTE_PREFIX='/tmp/yaog-alpha-'
            REMOTE_SUFFIX="${REMOTE_DIR#"$REMOTE_PREFIX"}"
            if [ "$REMOTE_DIR" != "$REMOTE_PREFIX$REMOTE_SUFFIX" ] || ! [[ "$REMOTE_SUFFIX" =~ ^[A-Za-z0-9]{8}$ ]]; then
                echo "  ERROR: Remote staging directory for "'alpha'" was not created safely." >&2
                FAILED=$((FAILED + 1))
                REMOTE_DIR=""
            fi
            if [ -n "$REMOTE_DIR" ] && scp -P 22 -r "$BUNDLE_DIR" 'root@alpha.example.com':"$REMOTE_DIR/bundle"; then
                if ssh -p 22 'root@alpha.example.com' "sudo bash '$REMOTE_DIR/bundle/install.sh'$INSTALL_ARGS; _yaog_rc=\$?; rm -rf -- '$REMOTE_DIR' || { [ \$_yaog_rc -ne 0 ] || _yaog_rc=1; }; exit \$_yaog_rc"; then
                    echo "  SUCCESS: "'alpha'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'alpha'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            elif [ -n "$REMOTE_DIR" ]; then
                echo "  ERROR: SCP upload to "'alpha'" failed." >&2
                ssh -p 22 'root@alpha.example.com' "rm -rf -- '$REMOTE_DIR'" >/dev/null 2>&1 || true
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: beta ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'beta'" ("'beta-alias'") ==="
    if ! ssh 'beta-alias' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'beta'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh 'beta-alias' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
_mimic_egress_if='wan0'
if [ -n "$_mimic_egress_if" ]; then
    echo "  Stopping mimic@$_mimic_egress_if..."
    systemctl disable --now "mimic@$_mimic_egress_if" 2>/dev/null || true
    rm -f "/etc/mimic/$_mimic_egress_if.conf"
fi
echo '[Stage 1/4] Stopping WireGuard interfaces on ''beta''...'
wg-quick down wg-alpha 2>/dev/null || true
systemctl disable wg-quick@wg-alpha 2>/dev/null || true
rm -f /etc/wireguard/wg-alpha.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 2/4] Stopping Babel routing daemon on ''beta''...'
systemctl stop babeld 2>/dev/null || true
systemctl disable babeld 2>/dev/null || true
rm -f /etc/babel/babeld.conf /etc/babeld.conf
rm -rf /etc/systemd/system/babeld.service.d
echo '[Stage 3/4] Removing overlay network configuration on ''beta''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
nft delete table inet overlay-snat 2>/dev/null || true
iptables-save -t nat 2>/dev/null | grep -E '^-A POSTROUTING ' | grep -F -- '-j SNAT' | grep -F -- '-o wg-+' | while IFS= read -r _snat_rule; do _snat_del="${_snat_rule/#-A/-D}"; iptables -t nat $_snat_del 2>/dev/null || true; done || true
systemctl disable overlay-snat.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-snat.service
ip link del dummy0 2>/dev/null || true
systemctl disable overlay-dummy.service 2>/dev/null || true
rm -f /etc/systemd/system/overlay-dummy.service
echo '[Stage 4/4] Reloading systemd on ''beta''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''beta''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'beta'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'beta'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'beta'" ("'beta-alias'") ==="
    BUNDLE_DIR=""
    if [ -d "$WORKDIR"/'beta' ]; then
        BUNDLE_DIR="$WORKDIR"/'beta'
    fi
    if [ -z "$BUNDLE_DIR" ] || [ ! -f "$BUNDLE_DIR/install.sh" ] || [ ! -f "$BUNDLE_DIR/checksums.sha256" ]; then
        echo "  WARNING: Complete bundle directory for "'beta'" not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        if ! ssh 'beta-alias' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'beta'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            REMOTE_DIR="$(ssh 'beta-alias' "mktemp -d -- '/tmp/yaog-beta-XXXXXXXX'")"
            REMOTE_PREFIX='/tmp/yaog-beta-'
            REMOTE_SUFFIX="${REMOTE_DIR#"$REMOTE_PREFIX"}"
            if [ "$REMOTE_DIR" != "$REMOTE_PREFIX$REMOTE_SUFFIX" ] || ! [[ "$REMOTE_SUFFIX" =~ ^[A-Za-z0-9]{8}$ ]]; then
                echo "  ERROR: Remote staging directory for "'beta'" was not created safely." >&2
                FAILED=$((FAILED + 1))
                REMOTE_DIR=""
            fi
            if [ -n "$REMOTE_DIR" ] && scp -r "$BUNDLE_DIR" 'beta-alias':"$REMOTE_DIR/bundle"; then
                if ssh 'beta-alias' "sudo bash '$REMOTE_DIR/bundle/install.sh'$INSTALL_ARGS; _yaog_rc=\$?; rm -rf -- '$REMOTE_DIR' || { [ \$_yaog_rc -ne 0 ] || _yaog_rc=1; }; exit \$_yaog_rc"; then
                    echo "  SUCCESS: "'beta'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'beta'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            elif [ -n "$REMOTE_DIR" ]; then
                echo "  ERROR: SCP upload to "'beta'" failed." >&2
                ssh 'beta-alias' "rm -rf -- '$REMOTE_DIR'" >/dev/null 2>&1 || true
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: gamma ---
echo ""
if [ "$UNINSTALL" -eq 1 ]; then
    echo "=== Uninstalling from "'gamma'" ("'deploy@10.0.0.9'") ==="
    if ! ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "echo ok" >/dev/null 2>&1; then
        echo "  ERROR: SSH connection to "'gamma'" failed." >&2
        FAILED=$((FAILED + 1))
    else
        if ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' sudo bash -s <<'UNINSTALL_EOF'; then
set -uo pipefail
echo '[Stage 1/4] Stopping WireGuard interfaces on ''gamma''...'
wg-quick down wg0 2>/dev/null || true
systemctl disable wg-quick@wg0 2>/dev/null || true
rm -f /etc/wireguard/wg0.conf
for _i in $(wg show interfaces 2>/dev/null); do wg-quick down "$_i" 2>/dev/null || true; systemctl disable "wg-quick@$_i" 2>/dev/null || true; done
rm -f /etc/wireguard/*.conf
echo '[Stage 3/4] Removing overlay network configuration on ''gamma''...'
rm -f /etc/sysctl.d/99-overlay.conf
sysctl --system > /dev/null 2>&1 || true
echo '[Stage 4/4] Reloading systemd on ''gamma''...'
systemctl daemon-reload || { echo 'ERROR: systemctl daemon-reload failed' >&2; exit 1; }
echo 'Overlay removed from ''gamma''.'

UNINSTALL_EOF
            echo "  SUCCESS: "'gamma'" uninstalled."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "  ERROR: Uninstall failed on "'gamma'" (exit code: $?)." >&2
            FAILED=$((FAILED + 1))
        fi
    fi
else
    echo "=== Deploying to "'gamma'" ("'deploy@10.0.0.9'") ==="
    BUNDLE_DIR=""
    if [ -d "$WORKDIR"/'gamma' ]; then
        BUNDLE_DIR="$WORKDIR"/'gamma'
    fi
    if [ -z "$BUNDLE_DIR" ] || [ ! -f "$BUNDLE_DIR/install.sh" ] || [ ! -f "$BUNDLE_DIR/checksums.sha256" ]; then
        echo "  WARNING: Complete bundle directory for "'gamma'" not found in archive, skipping."
        SKIPPED=$((SKIPPED + 1))
    else
        if ! ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "echo ok" >/dev/null 2>&1; then
            echo "  ERROR: SSH connection to "'gamma'" failed." >&2
            FAILED=$((FAILED + 1))
        else
            REMOTE_DIR="$(ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "mktemp -d -- '/tmp/yaog-gamma-XXXXXXXX'")"
            REMOTE_PREFIX='/tmp/yaog-gamma-'
            REMOTE_SUFFIX="${REMOTE_DIR#"$REMOTE_PREFIX"}"
            if [ "$REMOTE_DIR" != "$REMOTE_PREFIX$REMOTE_SUFFIX" ] || ! [[ "$REMOTE_SUFFIX" =~ ^[A-Za-z0-9]{8}$ ]]; then
                echo "  ERROR: Remote staging directory for "'gamma'" was not created safely." >&2
                FAILED=$((FAILED + 1))
                REMOTE_DIR=""
            fi
            if [ -n "$REMOTE_DIR" ] && scp -P 2222 -i '/home/op/keys/id_ed25519' -r "$BUNDLE_DIR" 'deploy@10.0.0.9':"$REMOTE_DIR/bundle"; then
                if ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "sudo bash '$REMOTE_DIR/bundle/install.sh'$INSTALL_ARGS; _yaog_rc=\$?; rm -rf -- '$REMOTE_DIR' || { [ \$_yaog_rc -ne 0 ] || _yaog_rc=1; }; exit \$_yaog_rc"; then
                    echo "  SUCCESS: "'gamma'" deployed."
                    SUCCESS=$((SUCCESS + 1))
                else
                    echo "  ERROR: Installation script failed on "'gamma'" (exit code: $?)." >&2
                    FAILED=$((FAILED + 1))
                fi
            elif [ -n "$REMOTE_DIR" ]; then
                echo "  ERROR: SCP upload to "'gamma'" failed." >&2
                ssh -p 2222 -i '/home/op/keys/id_ed25519' 'deploy@10.0.0.9' "rm -rf -- '$REMOTE_DIR'" >/dev/null 2>&1 || true
                FAILED=$((FAILED + 1))
            fi
        fi
    fi
fi

# --- Node: delta ---
echo ""
echo "=== "'delta'": SKIPPED (no SSH details configured) ==="
SKIPPED=$((SKIPPED + 1))

echo ""
echo "============================================================"
if [ "$UNINSTALL" -eq 1 ]; then
    echo "  Uninstall Summary"
else
    echo "  Deploy Summary"
fi
echo "  Success: $SUCCESS  Skipped: $SKIPPED  Failed: $FAILED"
echo "============================================================"

if [ "$FAILED" -gt 0 ]; then
    exit 1
fi
