# Sysctl configuration for {{ .NodeName }}
# Generated by Overlay Network Config Orchestrator

{{- if .EnableForwarding }}

# Enable IPv4 forwarding
net.ipv4.ip_forward = 1

# IPv6 forwarding (disabled by default)
# net.ipv6.conf.all.forwarding = 1

# Loose reverse-path filtering (Babel needs asymmetric routes)
net.ipv4.conf.all.rp_filter = 0
net.ipv4.conf.default.rp_filter = 0
{{- else }}

# Strict reverse-path filtering (pure peer node)
# rp_filter tightened; this is not a Babel forwarding node
net.ipv4.conf.all.rp_filter = 2
net.ipv4.conf.default.rp_filter = 2
{{- end }}
