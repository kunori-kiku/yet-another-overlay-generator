{
  "project": {
    "id": "nat-hub-001",
    "name": "NAT Hub",
    "description": "1 公网 hub + 2 NAT 客户端拓扑示例",
    "version": "0.1.0"
  },
  "domains": [
    {
      "id": "domain-1",
      "name": "hub-network",
      "cidr": "10.20.0.0/24",
      "allocation_mode": "auto",
      "routing_mode": "babel"
    }
  ],
  "nodes": [
    {
      "id": "hub-1",
      "name": "hub-server",
      "hostname": "hub.example.com",
      "platform": "debian",
      "role": "router",
      "domain_id": "domain-1",
      "listen_port": 51820,
      "capabilities": {
        "can_accept_inbound": true,
        "can_forward": true,
        "can_relay": true,
        "has_public_ip": true
      }
    },
    {
      "id": "client-1",
      "name": "nat-client-a",
      "hostname": "client-a.local",
      "platform": "ubuntu",
      "role": "peer",
      "domain_id": "domain-1",
      "listen_port": 51820,
      "capabilities": {
        "can_accept_inbound": false,
        "can_forward": false,
        "can_relay": false,
        "has_public_ip": false
      }
    },
    {
      "id": "client-2",
      "name": "nat-client-b",
      "hostname": "client-b.local",
      "platform": "ubuntu",
      "role": "peer",
      "domain_id": "domain-1",
      "listen_port": 51820,
      "capabilities": {
        "can_accept_inbound": false,
        "can_forward": false,
        "can_relay": false,
        "has_public_ip": false
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "from_node_id": "client-1",
      "to_node_id": "hub-1",
      "type": "public-endpoint",
      "endpoint_host": "198.51.100.1",
      "endpoint_port": 51820,
      "transport": "udp",
      "is_enabled": true,
      "notes": "NAT 客户端 A 主动连接公网 Hub"
    },
    {
      "id": "edge-2",
      "from_node_id": "client-2",
      "to_node_id": "hub-1",
      "type": "public-endpoint",
      "endpoint_host": "198.51.100.1",
      "endpoint_port": 51820,
      "transport": "udp",
      "is_enabled": true,
      "notes": "NAT 客户端 B 主动连接公网 Hub"
    }
  ]
}
